---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sell-through live por SKU</title>
  </head>

  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Chino Regalado · Bsale live</p>
        <h1>Sell-through live por SKU</h1>
        <p class="subtitle">
          Calcula stock actual, última recepción, ventas desde la última recepción y sell-through directamente desde Bsale.
        </p>
      </section>

      <section class="panel">
        <form id="search-form" class="search-form">
          <label>
            SKU o código de barras
            <input id="search-input" type="text" placeholder="Ej. LJNJ-00034" autocomplete="off" required />
          </label>

          <label>
            Sucursal
            <select id="office-select">
              <option value="2">CHINO LAS AMERICAS</option>
              <option value="3">CHINO LA HUERTA</option>
              <option value="4">CHINO LEON CENTRO</option>
            </select>
          </label>

          <label>
            Buscar recepción en
            <select id="lookback-select">
              <option value="10">Últimos 10 días</option>
              <option value="30" selected>Últimos 30 días</option>
              <option value="90">Últimos 90 días</option>
              <option value="180">Últimos 180 días</option>
              <option value="365">Últimos 365 días</option>
            </select>
          </label>

          <button id="search-button" type="submit">Calcular</button>
        </form>

        <div class="actions-row">
          <div id="status" class="status"></div>
          <button id="pdf-button" class="secondary-button" type="button" hidden>
            Descargar PDF
          </button>
        </div>

        <div id="result" class="result"></div>
      </section>
    </main>

    <script>
      import { supabase } from '../lib/supabase.js';
      import { jsPDF } from 'jspdf';

      const form = document.querySelector('#search-form');
      const input = document.querySelector('#search-input');
      const officeSelect = document.querySelector('#office-select');
      const lookbackSelect = document.querySelector('#lookback-select');
      const button = document.querySelector('#search-button');
      const pdfButton = document.querySelector('#pdf-button');
      const status = document.querySelector('#status');
      const result = document.querySelector('#result');

      let lastCalculation = null;

      const money = (value) => {
        return Number(value || 0).toLocaleString('es-MX', {
          style: 'currency',
          currency: 'MXN',
        });
      };

      const number = (value) => {
        return Number(value || 0).toLocaleString('es-MX', {
          maximumFractionDigits: 2,
        });
      };

      const pct = (value) => {
        if (value === null || value === undefined || value === '') return '—';
        return `${number(value)}%`;
      };

      const clamp = (value, min, max) => {
        return Math.max(min, Math.min(max, Number(value || 0)));
      };

      const numeric = (value) => {
        const parsed = Number(value ?? 0);
        return Number.isFinite(parsed) ? parsed : 0;
      };

      const text = (value) => {
        if (value === null || value === undefined || value === '') return '—';
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      };

      const setStatus = (message) => {
        status.textContent = message;
      };

      const setPdfAvailable = (available) => {
        pdfButton.hidden = !available;
      };

      const fileSafe = (value) => {
        return String(value || 'sku')
          .trim()
          .replace(/[^a-z0-9-_]+/gi, '-')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '')
          .toLowerCase();
      };

      const buildSalesTimeline = (movements = []) => {
        const byDate = new Map();

        for (const item of movements) {
          const group = item?.movement_group;
          if (group !== 'VENTA' && group !== 'DEVOLUCION') continue;

          const date = item.movement_date || 'Sin fecha';
          const current = byDate.get(date) || {
            date,
            sold: 0,
            returned: 0,
            net: 0,
            documents: 0,
            amount: 0,
          };

          const qty = numeric(item.quantity);
          const amount = numeric(item.total_amount_signed ?? item.total_amount);

          if (group === 'VENTA') current.sold += qty;
          if (group === 'DEVOLUCION') current.returned += qty;

          current.net = current.sold - current.returned;
          current.amount += amount;
          current.documents += 1;
          byDate.set(date, current);
        }

        return Array.from(byDate.values()).sort((a, b) => String(a.date).localeCompare(String(b.date)));
      };

      const sellThroughLevel = (value) => {
        const numericValue = Number(value || 0);

        if (numericValue >= 80) return 'Alto';
        if (numericValue >= 50) return 'Medio';
        if (numericValue >= 20) return 'Bajo';
        return 'Inicial';
      };

      const downloadPdf = async () => {
        if (!lastCalculation) return;

        pdfButton.disabled = true;
        const originalText = pdfButton.textContent;
        pdfButton.textContent = 'Generando PDF...';

        try {
          const data = lastCalculation;
          const stock = data.stock_matches?.[0] || {};
          const summary = data.summary || {};
          const reception = data.last_reception || {};
          const scanStats = data.scan_stats || {};
          const salesTimeline = buildSalesTimeline(data.movements || []);
          const salesTotals = salesTimeline.reduce(
            (acc, row) => {
              acc.sold += numeric(row.sold);
              acc.returned += numeric(row.returned);
              acc.net += numeric(row.net);
              acc.documents += numeric(row.documents);
              return acc;
            },
            { sold: 0, returned: 0, net: 0, documents: 0 },
          );
          const maxSold = Math.max(1, ...salesTimeline.map((row) => numeric(row.sold)));

          const pdf = new jsPDF({
            orientation: 'landscape',
            unit: 'pt',
            format: 'a4',
          });

          const pageWidth = pdf.internal.pageSize.getWidth();
          const pageHeight = pdf.internal.pageSize.getHeight();
          const margin = 34;
          const contentWidth = pageWidth - margin * 2;
          const dark = '#172033';
          const muted = '#64748b';
          const border = '#dbe3ef';
          const soft = '#f8fafc';
          const blue = '#2563eb';
          const green = '#166534';
          const red = '#991b1b';
          const amber = '#92400e';
          let y = margin;

          const safe = (value) => {
            if (value === null || value === undefined || value === '') return '—';
            return String(value);
          };

          const fmt = (value) => {
            return Number(value || 0).toLocaleString('es-MX', {
              maximumFractionDigits: 2,
            });
          };

          const fmtMoney = (value) => {
            return Number(value || 0).toLocaleString('es-MX', {
              style: 'currency',
              currency: 'MXN',
            });
          };

          const addFooter = () => {
            pdf.setFont('helvetica', 'normal');
            pdf.setFontSize(7);
            pdf.setTextColor(muted);
            pdf.text(
              `Generado ${new Date().toLocaleString('es-MX')} · Bsale live · ${safe(data.start_date)} a ${safe(data.end_date)}`,
              margin,
              pageHeight - 18,
            );
          };

          const addPage = () => {
            addFooter();
            pdf.addPage();
            y = margin;
          };

          const drawKpi = (x, yPos, w, h, label, value, note = '') => {
            pdf.setDrawColor(border);
            pdf.setFillColor(soft);
            pdf.roundedRect(x, yPos, w, h, 9, 9, 'FD');

            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(7.5);
            pdf.setTextColor(muted);
            pdf.text(label.toUpperCase(), x + 10, yPos + 16);

            pdf.setFontSize(18);
            pdf.setTextColor(dark);
            pdf.text(safe(value), x + 10, yPos + 39);

            if (note) {
              pdf.setFontSize(7.5);
              pdf.setTextColor(muted);
              pdf.text(safe(note), x + 10, yPos + 55, { maxWidth: w - 20 });
            }
          };

          const drawHeader = () => {
            pdf.setFont('helvetica', 'bold');
            pdf.setTextColor(muted);
            pdf.setFontSize(8);
            pdf.text('CHINO REGALADO · BSALE LIVE', margin, y);

            pdf.setFillColor('#dcfce7');
            pdf.roundedRect(pageWidth - margin - 92, y - 11, 92, 18, 9, 9, 'F');
            pdf.setTextColor(green);
            pdf.text('Calculado live', pageWidth - margin - 78, y + 1);
            y += 26;

            pdf.setTextColor(dark);
            pdf.setFontSize(27);
            pdf.text('Reporte sell-through por SKU', margin, y);
            y += 23;

            pdf.setFont('helvetica', 'normal');
            pdf.setFontSize(9.5);
            pdf.setTextColor(muted);
            pdf.text(
              `SKU: ${safe(stock.sku || data.query)}   ·   Sucursal: ${safe(stock.office_name)}   ·   Consulta: ${new Date().toLocaleString('es-MX')}`,
              margin,
              y,
            );
            y += 28;
          };

          drawHeader();

          const summaryY = y;
          const summaryH = 154;
          pdf.setDrawColor(border);
          pdf.setFillColor('#ffffff');
          pdf.roundedRect(margin, summaryY, contentWidth, summaryH, 14, 14, 'FD');

          const panelX = margin + 14;
          const panelY = summaryY + 14;
          const panelW = 184;
          const panelH = summaryH - 28;
          pdf.setFillColor(dark);
          pdf.roundedRect(panelX, panelY, panelW, panelH, 12, 12, 'F');

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(29);
          pdf.setTextColor('#ffffff');
          pdf.text(`${fmt(summary.sell_through_pct)}%`, panelX + 18, panelY + 44);

          pdf.setFontSize(8.5);
          pdf.text('SELL-THROUGH', panelX + 18, panelY + 66);

          pdf.setFont('helvetica', 'normal');
          pdf.setFontSize(8);
          pdf.setTextColor('#cbd5e1');
          pdf.text('desde última recepción', panelX + 18, panelY + 82);
          pdf.text(
            `${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)} piezas netas de ${fmt(summary.piezas_recibidas_ultima_recepcion)} recibidas`,
            panelX + 18,
            panelY + 104,
            { maxWidth: panelW - 36 },
          );

          const rightX = panelX + panelW + 18;
          const rightW = contentWidth - panelW - 46;
          const gap = 12;
          const kpiW = (rightW - gap) / 2;
          const kpiH = 58;
          drawKpi(rightX, panelY, kpiW, kpiH, 'Recibidas', fmt(summary.piezas_recibidas_ultima_recepcion), `Recepción ${safe(reception.reception_id)}`);
          drawKpi(rightX + kpiW + gap, panelY, kpiW, kpiH, 'Vendidas', fmt(summary.piezas_vendidas_desde_ultima_recepcion), `Devueltas: ${fmt(summary.piezas_devueltas_desde_ultima_recepcion)}`);
          drawKpi(rightX, panelY + kpiH + gap, kpiW, kpiH, 'Stock actual', fmt(summary.stock_actual), `Disponible: ${fmt(summary.stock_disponible)}`);
          drawKpi(rightX + kpiW + gap, panelY + kpiH + gap, kpiW, kpiH, 'Venta neta', fmt(summary.piezas_netas_venta_desde_ultima_recepcion), `Desde ${safe(reception.movement_date)}`);
          y += summaryH + 24;

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(15);
          pdf.setTextColor(dark);
          pdf.text('Recepción y ventas en el tiempo', margin, y);
          y += 18;

          const receptionH = 84;
          pdf.setDrawColor(border);
          pdf.setFillColor('#ffffff');
          pdf.roundedRect(margin, y, contentWidth, receptionH, 12, 12, 'FD');
          pdf.setFontSize(7.5);
          pdf.setTextColor(muted);
          pdf.text('ÚLTIMA RECEPCIÓN', margin + 14, y + 17);
          pdf.setFontSize(13);
          pdf.setTextColor(dark);
          pdf.text(`Recepción ${safe(reception.reception_id)} · ${safe(reception.movement_date)}`, margin + 14, y + 37);
          pdf.setFont('helvetica', 'normal');
          pdf.setFontSize(8.5);
          pdf.text(
            `Piezas: ${fmt(reception.quantity)} · Costo: ${fmtMoney(reception.cost)} · Stock al recibir: ${fmt(reception.variant_stock)} · Nota: ${safe(reception.note)}`,
            margin + 14,
            y + 58,
            { maxWidth: contentWidth - 28 },
          );
          y += receptionH + 24;

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(8);
          pdf.setTextColor(muted);
          pdf.text('VENTAS AGRUPADAS POR DÍA', margin, y);

          pdf.setFont('helvetica', 'bold');
          pdf.setTextColor(dark);
          pdf.text(`${fmt(salesTotals.sold)} vendidas`, pageWidth - margin - 210, y);
          pdf.text(`${fmt(salesTotals.returned)} devueltas`, pageWidth - margin - 135, y);
          pdf.text(`${fmt(salesTotals.net)} netas`, pageWidth - margin - 52, y);
          y += 16;

          const drawSalesHeader = () => {
            pdf.setFillColor('#eef2f7');
            pdf.roundedRect(margin, y, contentWidth, 22, 8, 8, 'F');
            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(7.5);
            pdf.setTextColor(muted);
            pdf.text('FECHA', margin + 10, y + 14);
            pdf.text('VENDIDAS', margin + 100, y + 14);
            pdf.text('DEVUELTAS', margin + 168, y + 14);
            pdf.text('NETAS', margin + 252, y + 14);
            pdf.text('DOCS', margin + 312, y + 14);
            pdf.text('VOLUMEN DIARIO', margin + 370, y + 14);
            y += 28;
          };

          const drawSalesRow = (row) => {
            if (y > pageHeight - 58) {
              addPage();
              pdf.setFont('helvetica', 'bold');
              pdf.setFontSize(13);
              pdf.setTextColor(dark);
              pdf.text('Ventas agrupadas por día · continuación', margin, y);
              y += 18;
              drawSalesHeader();
            }

            const rowH = 27;
            pdf.setDrawColor('#e2e8f0');
            pdf.line(margin, y + rowH, margin + contentWidth, y + rowH);

            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(8.5);
            pdf.setTextColor(dark);
            pdf.text(safe(row.date), margin + 10, y + 17);

            pdf.setFont('helvetica', 'normal');
            pdf.setTextColor(muted);
            pdf.text(fmt(row.sold), margin + 100, y + 17);
            pdf.text(fmt(row.returned), margin + 168, y + 17);

            const netColor = row.net < 0 ? red : row.returned > 0 ? amber : green;
            pdf.setFont('helvetica', 'bold');
            pdf.setTextColor(netColor);
            pdf.text(fmt(row.net), margin + 252, y + 17);

            pdf.setTextColor(muted);
            pdf.text(fmt(row.documents), margin + 312, y + 17);

            const barX = margin + 370;
            const barW = contentWidth - 390;
            const barY = y + 9;
            const barFill = row.sold > 0 ? Math.max(4, (numeric(row.sold) / maxSold) * barW) : 0;
            pdf.setFillColor('#e2e8f0');
            pdf.roundedRect(barX, barY, barW, 9, 5, 5, 'F');
            if (barFill > 0) {
              pdf.setFillColor(blue);
              pdf.roundedRect(barX, barY, barFill, 9, 5, 5, 'F');
            }

            y += rowH;
          };

          if (salesTimeline.length) {
            drawSalesHeader();
            for (const row of salesTimeline) drawSalesRow(row);
          } else {
            pdf.setFont('helvetica', 'normal');
            pdf.setFontSize(9);
            pdf.setTextColor(muted);
            pdf.text('No hay ventas ni devoluciones posteriores a la última recepción.', margin, y + 14);
            y += 28;
          }

          if (y < pageHeight - 90) {
            y += 18;
            pdf.setDrawColor(border);
            pdf.setFillColor('#f8fafc');
            pdf.roundedRect(margin, y, contentWidth, 54, 10, 10, 'FD');
            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(7.5);
            pdf.setTextColor(muted);
            pdf.text('COBERTURA REVISADA', margin + 12, y + 17);
            pdf.setFont('helvetica', 'normal');
            pdf.setFontSize(7.5);
            pdf.setTextColor(dark);
            pdf.text(
              `Recepciones: ${fmt(scanStats.receptions?.receptions_seen)} · Recepciones con SKU: ${fmt(scanStats.receptions?.matches)} · Documentos: ${fmt(scanStats.documents?.documents_seen)} · Líneas: ${fmt(scanStats.documents?.details_seen)} · Movimientos del SKU: ${fmt(scanStats.documents?.matches)}`,
              margin + 12,
              y + 36,
              { maxWidth: contentWidth - 24 },
            );
          }

          addFooter();

          const sku = input.value.trim() || 'sku';
          const date = new Date().toISOString().slice(0, 10);
          pdf.save(`sell-through-${fileSafe(sku)}-${date}.pdf`);
        } finally {
          pdfButton.disabled = false;
          pdfButton.textContent = originalText;
        }
      };

      pdfButton.addEventListener('click', downloadPdf);

      const renderNotFound = (data) => {
        lastCalculation = data;
        setPdfAvailable(false);

        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Resultado</p>
                <h2>SKU no encontrado</h2>
              </div>
              <span class="badge neutral">Sin coincidencia</span>
            </div>

            <p class="muted">
              No se encontró variant_id para <strong>${text(data?.query || input.value)}</strong>
              en el índice técnico de Supabase.
            </p>

            <p class="muted small-note">
              Esto puede pasar si el SKU es nuevo, si la recepción aún no está finalizada en Bsale,
              o si el índice de stock actual no se ha sincronizado.
            </p>
          </section>
        `;
      };

      const renderNoReception = (data) => {
        lastCalculation = data;
        const stock = data.stock_matches?.[0];
        const summary = data.summary || {};

        setPdfAvailable(false);

        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Bsale live</p>
                <h2>SKU encontrado, sin recepción en rango</h2>
              </div>
              <span class="badge warning">Sin última recepción</span>
            </div>

            <div class="summary-grid">
              <article class="card primary">
                <span>SKU</span>
                <strong>${text(stock?.sku || data.query)}</strong>
                <small>${text(stock?.office_name)}</small>
              </article>

              <article class="card">
                <span>Stock actual</span>
                <strong>${number(summary.stock_actual)}</strong>
                <small>Disponible: ${number(summary.stock_disponible)}</small>
              </article>

              <article class="card">
                <span>Variant ID</span>
                <strong>${text(data.variant_ids?.join(', '))}</strong>
                <small>Rango: ${text(data.start_date)} a ${text(data.end_date)}</small>
              </article>
            </div>

            <p class="muted block-note">
              El SKU existe, pero no se encontró recepción dentro del rango consultado.
              Amplía el rango de búsqueda y vuelve a calcular.
            </p>
          </section>
        `;
      };

      const renderData = (data) => {
        lastCalculation = data;

        if (!data?.found) {
          renderNotFound(data);
          return;
        }

        if (!data?.sell_through_found) {
          renderNoReception(data);
          return;
        }

        const stock = data.stock_matches?.[0];
        const summary = data.summary || {};
        const reception = data.last_reception || {};
        const movements = data.movements || [];
        const scanStats = data.scan_stats || {};
        const salesTimeline = buildSalesTimeline(movements);
        const salesTotals = salesTimeline.reduce(
          (acc, row) => {
            acc.sold += numeric(row.sold);
            acc.returned += numeric(row.returned);
            acc.net += numeric(row.net);
            acc.documents += numeric(row.documents);
            return acc;
          },
          { sold: 0, returned: 0, net: 0, documents: 0 },
        );

        const maxSold = Math.max(1, ...salesTimeline.map((row) => numeric(row.sold)));
        const sellThroughValue = Number(summary.sell_through_pct || 0);
        const sellThroughClamped = clamp(sellThroughValue, 0, 100);
        const sellThroughStatus = sellThroughLevel(sellThroughValue);

        setPdfAvailable(true);

        const salesTimelineHtml = salesTimeline.length
          ? `<div class="sales-timeline">
              ${salesTimeline
                .map((row) => {
                  const soldWidth = row.sold > 0 ? Math.max(4, (row.sold / maxSold) * 100) : 0;
                  const netClass = row.net < 0 ? 'negative' : row.returned > 0 ? 'warning' : 'success';

                  return `
                    <article class="sales-day">
                      <div class="sales-date">
                        <span>${text(row.date)}</span>
                        <small>${number(row.documents)} docs</small>
                      </div>

                      <div class="sales-day-main">
                        <div class="sales-bar-shell">
                          <div class="sales-bar" style="width: ${soldWidth}%"></div>
                        </div>

                        <div class="sales-metrics">
                          <span><strong>${number(row.sold)}</strong> vendidas</span>
                          <span><strong>${number(row.returned)}</strong> devueltas</span>
                          <span class="${netClass}"><strong>${number(row.net)}</strong> netas</span>
                        </div>
                      </div>
                    </article>
                  `;
                })
                .join('')}
            </div>`
          : `<p class="muted block-note">No hay ventas ni devoluciones posteriores a la última recepción.</p>`;

        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Resultado live</p>
                <h2>${text(stock?.sku || data.query)}</h2>
              </div>
              <span class="badge success">Calculado desde Bsale</span>
            </div>

            <div class="result-layout">
              <article class="sellthrough-panel">
                <div class="gauge" style="--value: ${sellThroughClamped};">
                  <div class="gauge-inner">
                    <strong>${pct(summary.sell_through_pct)}</strong>
                    <span>${sellThroughStatus}</span>
                  </div>
                </div>

                <div>
                  <p class="metric-label">Sell-through desde última recepción</p>
                  <p class="metric-help">
                    ${number(summary.piezas_netas_venta_desde_ultima_recepcion)}
                    piezas netas vendidas de
                    ${number(summary.piezas_recibidas_ultima_recepcion)}
                    recibidas.
                  </p>
                </div>
              </article>

              <div class="summary-grid compact">
                <article class="card">
                  <span>Piezas recibidas</span>
                  <strong>${number(summary.piezas_recibidas_ultima_recepcion)}</strong>
                  <small>Recepción ${text(reception.reception_id)}</small>
                </article>

                <article class="card">
                  <span>Piezas vendidas</span>
                  <strong>${number(summary.piezas_vendidas_desde_ultima_recepcion)}</strong>
                  <small>Devueltas: ${number(summary.piezas_devueltas_desde_ultima_recepcion)}</small>
                </article>

                <article class="card">
                  <span>Stock actual</span>
                  <strong>${number(summary.stock_actual)}</strong>
                  <small>Disponible: ${number(summary.stock_disponible)}</small>
                </article>

                <article class="card">
                  <span>Venta neta piezas</span>
                  <strong>${number(summary.piezas_netas_venta_desde_ultima_recepcion)}</strong>
                  <small>Desde ${text(reception.movement_date)}</small>
                </article>
              </div>
            </div>
          </section>

          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Recepción y ventas</p>
                <h2>Línea temporal desde última recepción</h2>
              </div>
              <span class="badge neutral">${number(salesTimeline.length)} días con venta</span>
            </div>

            <div class="flow-layout">
              <article class="reception-origin">
                <div class="origin-marker"></div>
                <div>
                  <p class="origin-label">Última recepción</p>
                  <h3>Recepción ${text(reception.reception_id)}</h3>
                  <dl>
                    <div>
                      <dt>Fecha</dt>
                      <dd>${text(reception.movement_date)}</dd>
                    </div>
                    <div>
                      <dt>Piezas recibidas</dt>
                      <dd>${number(reception.quantity)}</dd>
                    </div>
                    <div>
                      <dt>Costo</dt>
                      <dd>${money(reception.cost)}</dd>
                    </div>
                    <div>
                      <dt>Stock al recibir</dt>
                      <dd>${number(reception.variant_stock)}</dd>
                    </div>
                    <div class="wide">
                      <dt>Nota</dt>
                      <dd>${text(reception.note)}</dd>
                    </div>
                  </dl>
                </div>
              </article>

              <article class="sales-flow-card">
                <div class="sales-flow-header">
                  <div>
                    <p class="origin-label">Ventas agrupadas por día</p>
                    <h3>Comportamiento posterior a la recepción</h3>
                  </div>

                  <div class="flow-totals">
                    <span><strong>${number(salesTotals.sold)}</strong> vendidas</span>
                    <span><strong>${number(salesTotals.returned)}</strong> devueltas</span>
                    <span><strong>${number(salesTotals.net)}</strong> netas</span>
                  </div>
                </div>

                ${salesTimelineHtml}
              </article>
            </div>
          </section>

          <section class="section-card muted-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Cobertura revisada</p>
                <h2>Qué se revisó en Bsale</h2>
              </div>
              <span class="badge neutral">Diagnóstico</span>
            </div>

            <div class="coverage-grid">
              <article class="coverage-item">
                <span>Rango consultado</span>
                <strong>${text(data.start_date)} a ${text(data.end_date)}</strong>
                <p>Periodo usado para encontrar la última recepción y las ventas posteriores.</p>
              </article>

              <article class="coverage-item">
                <span>Recepciones revisadas</span>
                <strong>${number(scanStats.receptions?.receptions_seen)}</strong>
                <p>Recepciones de Bsale leídas para buscar la última entrada de este SKU.</p>
              </article>

              <article class="coverage-item">
                <span>Recepciones con este SKU</span>
                <strong>${number(scanStats.receptions?.matches)}</strong>
                <p>Coincidencias encontradas del SKU dentro de las recepciones revisadas.</p>
              </article>

              <article class="coverage-item">
                <span>Documentos de venta revisados</span>
                <strong>${number(scanStats.documents?.documents_seen)}</strong>
                <p>Documentos revisados desde la fecha de la última recepción hasta hoy.</p>
              </article>

              <article class="coverage-item">
                <span>Líneas de documento revisadas</span>
                <strong>${number(scanStats.documents?.details_seen)}</strong>
                <p>Renglones de productos revisados dentro de esos documentos.</p>
              </article>

              <article class="coverage-item">
                <span>Ventas/devoluciones del SKU</span>
                <strong>${number(scanStats.documents?.matches)}</strong>
                <p>Movimientos de venta o devolución encontrados para este SKU.</p>
              </article>
            </div>
          </section>
        `;
      };

      const renderError = (error) => {
        setPdfAvailable(false);

        result.innerHTML = `
          <section class="section-card error-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Error</p>
                <h2>No se pudo calcular</h2>
              </div>
              <span class="badge danger">Error</span>
            </div>

            <p class="muted">${text(error?.message || error)}</p>
          </section>
        `;
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const searchValue = input.value.trim();
        const officeId = Number(officeSelect.value);
        const lookbackDays = Number(lookbackSelect.value);

        if (!searchValue) {
          setStatus('Escribe un SKU o código de barras.');
          result.innerHTML = '';
          return;
        }

        button.disabled = true;
        lastCalculation = null;
        setPdfAvailable(false);
        result.innerHTML = '';
        setStatus('Calculando sell-through live desde Bsale...');

        const { data, error } = await supabase.functions.invoke('calculate-sell-through-live', {
          body: {
            query: searchValue,
            office_ids: [officeId],
            lookback_days: lookbackDays,
            max_reception_pages_per_office: 0,
            max_document_pages_per_day_type: 0,
            max_reception_details: 1000,
          },
        });

        button.disabled = false;
        setStatus('');

        if (error) {
          renderError(error);
          return;
        }

        if (data?.error) {
          renderError(data.error);
          return;
        }

        renderData(data);
      });
    </script>
  </body>
</html>

