---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sell-through live por SKU</title>
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Chino Regalado · Bsale live · v2</p>
        <h1>Sell-through live por SKU</h1>
        <p class="subtitle">Analiza movimientos por última recepción o por periodo explícito. La operación documental cierra hasta ayer.</p>
      </section>
      <section class="panel">
        <form id="search-form" class="search-form">
          <label>SKU o código de barras<input id="search-input" type="text" placeholder="Ej. ROPACR" autocomplete="off" required /></label>
          <label>Sucursal<select id="office-select"><option value="2">CHINO LAS AMERICAS</option><option value="3">CHINO LA HUERTA</option><option value="4">CHINO LEON CENTRO</option></select></label>
          <label>Buscar recepción en<select id="mode-select"><option value="last_reception" selected>Última recepción</option><option value="period">Periodo</option></select></label>
          <label class="period-field" hidden>Fecha inicial<input id="period-start" type="date" /></label>
          <label class="period-field" hidden>Fecha final<input id="period-end" type="date" /></label>
          <button id="search-button" type="submit">Calcular</button>
        </form>
        <div class="actions-row"><div id="status" class="status"></div><button id="pdf-button" class="secondary-button" type="button" hidden>Descargar PDF</button></div>
        <div id="result" class="result"></div>
      </section>
    </main>

    <script>
      import { supabase } from '../lib/supabase.js';
      import { jsPDF } from 'jspdf';

      const form = document.querySelector('#search-form');
      const input = document.querySelector('#search-input');
      const officeSelect = document.querySelector('#office-select');
      const modeSelect = document.querySelector('#mode-select');
      const periodFields = Array.from(document.querySelectorAll('.period-field'));
      const periodStart = document.querySelector('#period-start');
      const periodEnd = document.querySelector('#period-end');
      const button = document.querySelector('#search-button');
      const pdfButton = document.querySelector('#pdf-button');
      const status = document.querySelector('#status');
      const result = document.querySelector('#result');
      let lastCalculation = null;

      const num = (v) => { const p = Number(v ?? 0); return Number.isFinite(p) ? p : 0; };
      const fmt = (v) => num(v).toLocaleString('es-MX', { maximumFractionDigits: 2 });
      const money = (v) => num(v).toLocaleString('es-MX', { style: 'currency', currency: 'MXN' });
      const pct = (v) => v === null || v === undefined || v === '' ? '—' : `${fmt(v)}%`;
      const esc = (v) => String(v ?? '—').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;');
      const plain = (v) => String(v ?? '—');
      const ymd = () => new Date().toISOString().slice(0, 10);
      const yesterday = () => { const d = new Date(); d.setUTCDate(d.getUTCDate() - 1); return d.toISOString().slice(0, 10); };
      const daysAgo = (days) => { const d = new Date(); d.setUTCDate(d.getUTCDate() - days); return d.toISOString().slice(0, 10); };
      const daysSinceDate = (value) => {
        if (!value) return null;

        const receptionDate = Date.parse(`${value}T00:00:00Z`);

        if (!Number.isFinite(receptionDate)) return null;

        const now = new Date();
        const todayUtc = Date.UTC(
          now.getUTCFullYear(),
          now.getUTCMonth(),
          now.getUTCDate(),
        );

        return Math.max(
          0,
          Math.floor((todayUtc - receptionDate) / 86_400_000),
        );
      };
      const setStatus = (message) => { status.textContent = message; };
      const showPdf = (value) => { pdfButton.hidden = !value; };
      const fileSafe = (v) => String(v || 'sku').trim().replace(/[^a-z0-9-_]+/gi, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').toLowerCase();

      const updateModeUi = () => {
        const isPeriod = modeSelect.value === 'period';
        periodFields.forEach((field) => { field.hidden = !isPeriod; });
        form.classList.toggle('period-mode', isPeriod);
        if (isPeriod) {
          if (!periodStart.value) periodStart.value = daysAgo(30);
          if (!periodEnd.value) periodEnd.value = yesterday();
          periodEnd.max = yesterday();
        }
      };
      modeSelect.addEventListener('change', updateModeUi);
      updateModeUi();

      const groupByDay = (movements = []) => {
        const map = new Map();
        for (const movement of movements) {
          const date = movement.movement_date || 'Sin fecha';
          const row = map.get(date) || { date, received: 0, sold: 0, returned: 0, consumed: 0, stockOut: 0, movements: 0 };
          const qty = num(movement.quantity);
          if (movement.movement_group === 'ENTRADA') row.received += qty;
          if (movement.movement_group === 'VENTA') row.sold += qty;
          if (movement.movement_group === 'DEVOLUCION') row.returned += qty;
          if (movement.movement_group === 'CONSUMO_AJUSTE') row.consumed += qty;
          row.stockOut = row.sold - row.returned + row.consumed;
          row.movements += 1;
          map.set(date, row);
        }
        return Array.from(map.values()).sort((a, b) => String(a.date).localeCompare(String(b.date)));
      };
      const movementLabel = (m) => m.movement_group === 'ENTRADA' ? 'Recepción' : m.movement_group === 'VENTA' ? 'Venta' : m.movement_group === 'DEVOLUCION' ? 'Devolución' : m.movement_group === 'CONSUMO_AJUSTE' ? 'Consumo / ajuste' : 'Movimiento';
      const movementClass = (m) => m.movement_group === 'ENTRADA' ? 'in' : m.movement_group === 'CONSUMO_AJUSTE' ? 'adjust' : m.movement_group === 'DEVOLUCION' ? 'return' : 'sale';

      const renderError = (message) => { showPdf(false); result.innerHTML = `<section class="section-card error-card"><div class="section-header"><div><p class="section-kicker">Error</p><h2>No se pudo calcular</h2></div><span class="badge danger">Error</span></div><p class="muted">${esc(message?.message || message)}</p></section>`; };
      const renderNoReception = (data) => {
        const stock = data.stock_matches?.[0] || {}; const summary = data.summary || {}; showPdf(false);
        result.innerHTML = `<section class="section-card"><div class="section-header"><div><p class="section-kicker">Resultado</p><h2>SKU encontrado, sin recepción</h2></div><span class="badge warning">Sin entrada</span></div><div class="summary-grid compact"><article class="card primary"><span>SKU</span><strong>${esc(stock.sku || data.query)}</strong><small>${esc(stock.office_name)}</small></article><article class="card"><span>Stock actual Bsale live</span><strong>${fmt(summary.stock_actual)}</strong><small>Disponible: ${fmt(summary.stock_disponible)}</small></article><article class="card"><span>Rango</span><strong>${esc(data.start_date)} a ${esc(data.end_date)}</strong><small>Variant ID ${esc(data.variant_ids?.join(', '))}</small></article></div></section>`;
      };

      const renderData = (data) => {
        lastCalculation = data;
        if (!data?.found) return renderError(data?.message || 'SKU no encontrado.');
        if (!data?.sell_through_found) return renderNoReception(data);
        showPdf(true);
        const isPeriod = data.analysis_mode === 'period';
        const stock = data.stock_matches?.[0] || {};
        const summary = data.summary || {};
        const reception = data.last_reception || {};
        const daysSinceLastReception = daysSinceDate(
          reception.movement_date,
        );

        const receptionAgeDanger =
          daysSinceLastReception !== null &&
          daysSinceLastReception > 35 &&
          num(summary.sell_through_pct) < 100;

        const stats = data.scan_stats || {};
        const movements = data.movements || [];
        const timeline = groupByDay(movements);
        const modeTitle = isPeriod ? 'Periodo explícito' : 'Última recepción';
        const receivedNote = isPeriod ? `${fmt(data.period_receptions?.length || 0)} recepciones dentro del periodo` : `Recepción ${esc(reception.reception_id)} · ${esc(reception.movement_date)}`;
        const warning = summary.advertencia_salidas_superan_ultima_recepcion ? `<section class="section-card warning-card"><div class="section-header tight"><div><p class="section-kicker">Advertencia</p><h2>Las salidas superan las entradas del rango</h2></div><span class="badge warning">Revisar</span></div><p class="muted block-note">${esc(summary.nota_trazabilidad)}</p></section>` : '';
        const timelineHtml = timeline.map((row) => `<article class="timeline-day"><div class="timeline-date"><strong>${esc(row.date)}</strong><small>${fmt(row.movements)} movimientos</small></div><div class="pill-row"><span><strong>${fmt(row.received)}</strong> recibidas</span><span><strong>${fmt(row.sold)}</strong> vendidas</span><span><strong>${fmt(row.returned)}</strong> devueltas</span><span><strong>${fmt(row.consumed)}</strong> ajustes</span><span><strong>${fmt(row.stockOut)}</strong> salidas stock</span></div></article>`).join('');
        const movementsHtml = movements.slice(0, 120).map((movement) => `<article class="movement-row ${movementClass(movement)}"><div><strong>${esc(movementLabel(movement))}</strong><small>${esc(movement.movement_date)} · ${esc(movement.note)}</small></div><div class="movement-qty"><strong>${fmt(movement.quantity_signed ?? movement.quantity)}</strong><small>piezas</small></div></article>`).join('');
        const context = isPeriod
          ? `<section class="section-card"><div class="section-header"><div><p class="section-kicker">Periodo analizado</p><h2>${esc(data.start_date)} a ${esc(data.end_date)}</h2></div><span class="badge neutral">Periodo</span></div><dl class="detail-grid"><div><dt>Fecha inicial</dt><dd>${esc(data.start_date)}</dd></div><div><dt>Fecha final</dt><dd>${esc(data.end_date)}</dd></div><div><dt>Recepciones</dt><dd>${fmt(data.period_receptions?.length || 0)}</dd></div><div><dt>Piezas recibidas</dt><dd>${fmt(summary.piezas_recibidas_periodo ?? summary.piezas_recibidas_ultima_recepcion)}</dd></div><div><dt>Vendidas netas</dt><dd>${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)}</dd></div><div><dt>Ajustes stock</dt><dd>${fmt(summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion)}</dd></div></dl></section>`
          : `<section class="section-card"><div class="section-header"><div><p class="section-kicker">Última recepción</p><h2>Recepción ${esc(reception.reception_id)}</h2></div><span class="badge neutral">${esc(reception.movement_type)}</span></div><dl class="detail-grid"><div><dt>Fecha</dt><dd>${esc(reception.movement_date)}</dd></div><div><dt>Piezas</dt><dd>${fmt(reception.quantity)}</dd></div><div><dt>Costo</dt><dd>${money(reception.cost)}</dd></div><div><dt>Stock al recibir</dt><dd>${fmt(reception.variant_stock)}</dd></div><div><dt>Documento</dt><dd>${esc(reception.document_number)}</dd></div><div><dt>Despacho interno</dt><dd>${esc(reception.internal_dispatch_id)}</dd></div><div class="wide"><dt>Nota</dt><dd>${esc(reception.note)}</dd></div></dl></section>`;
        result.innerHTML = `${warning}<section class="section-card"><div class="section-header"><div><p class="section-kicker">Resultado live · ${esc(modeTitle)}</p><h2>${esc(stock.sku || data.query)}</h2></div><span class="badge success">${esc(data.function_version)}</span></div><div class="result-layout"><div class="hero-metrics"><article class="sellthrough-panel"><div class="gauge" style="--value:${Math.max(0, Math.min(100, num(summary.sell_through_pct)))};"><div class="gauge-inner"><strong>${pct(summary.sell_through_pct)}</strong><span>venta</span></div></div><div><p class="metric-label">Sell-through por venta</p><p class="metric-help">${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)} piezas netas vendidas de ${fmt(summary.piezas_recibidas_ultima_recepcion)} recibidas.</p></div>
</article>

<article class="reception-age-panel ${
  receptionAgeDanger ? 'danger' : ''
}" >
  <div>
    <p class="metric-label">
      Días desde última recepción
    </p>

    <strong class="reception-age-value">
      ${
        daysSinceLastReception === null
          ? '—'
          : fmt(daysSinceLastReception)
      }
    </strong>

    <p class="metric-help">
      ${
        daysSinceLastReception === null
          ? 'Fecha de recepción no disponible.'
          : receptionAgeDanger
            ? `Última recepción: ${esc(
                reception.movement_date,
              )} · Más de 35 días`
            : `Última recepción: ${esc(
                reception.movement_date,
              )}`
      }
    </p>
  </div>
</article>
</div>

<div class="summary-grid compact"><article class="card"><span>Recibidas</span><strong>${fmt(summary.piezas_recibidas_ultima_recepcion)}</strong><small>${receivedNote}</small></article><article class="card"><span>Vendidas netas</span><strong>${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)}</strong><small>Vendidas: ${fmt(summary.piezas_vendidas_desde_ultima_recepcion)} · Devueltas: ${fmt(summary.piezas_devueltas_desde_ultima_recepcion)}</small></article><article class="card"><span>Consumo / ajuste</span><strong>${fmt(summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion)}</strong><small>Salidas no venta que afectaron stock</small></article><article class="card"><span>Salidas stock</span><strong>${fmt(summary.piezas_salidas_stock_desde_ultima_recepcion)}</strong><small>${pct(summary.salidas_vs_recepcion_pct)} de entradas</small></article><article class="card"><span>Stock actual Bsale live</span><strong>${fmt(summary.stock_actual)}</strong><small>Disponible: ${fmt(summary.stock_disponible)}</small></article><article class="card"><span>Sucursal</span><strong>${esc(stock.office_name)}</strong><small>Variant ID ${esc(data.variant_ids?.join(', '))}</small></article></div></div><p class="muted block-note">Movimientos calculados hasta ${esc(data.end_date)}. El stock actual es live de Bsale.</p></section>${context}<section class="section-card"><div class="section-header"><div><p class="section-kicker">Movimientos por día</p><h2>Recepciones, ventas, devoluciones y ajustes</h2></div><span class="badge neutral">${fmt(timeline.length)} días</span></div><div class="timeline">${timelineHtml || '<p class="muted">Sin movimientos.</p>'}</div></section><section class="section-card muted-card"><div class="section-header"><div><p class="section-kicker">Cobertura revisada</p><h2>Qué leyó la función en Bsale</h2></div><span class="badge neutral">Diagnóstico</span></div><div class="coverage-grid"><article class="coverage-item"><span>Rango</span><strong>${esc(data.scan_start_date || data.start_date)} a ${esc(data.end_date)}</strong><p>Modo: ${esc(modeTitle)}</p></article><article class="coverage-item"><span>Recepciones revisadas</span><strong>${fmt(stats.receptions?.receptions_seen)}</strong><p>Coincidencias: ${fmt(stats.receptions?.matches)}</p></article><article class="coverage-item"><span>Documentos revisados</span><strong>${fmt(stats.documents?.documents_seen)}</strong><p>Líneas: ${fmt(stats.documents?.details_seen)} · matches: ${fmt(stats.documents?.matches)}</p></article><article class="coverage-item"><span>Consumos revisados</span><strong>${fmt(stats.consumptions?.consumptions_seen_in_date_range)}</strong><p>Líneas: ${fmt(stats.consumptions?.details_seen)} · matches: ${fmt(stats.consumptions?.matches)}</p></article><article class="coverage-item"><span>Política</span><strong>Hasta ayer</strong><p>${esc(data.data_policy)}</p></article><article class="coverage-item"><span>Errores API</span><strong>${fmt((stats.receptions?.detail_errors || []).length + (stats.documents?.detail_errors || []).length + (stats.consumptions?.detail_errors || []).length)}</strong><p>Errores acumulados.</p></article></div></section><section class="section-card"><div class="section-header"><div><p class="section-kicker">Detalle</p><h2>Movimientos detectados</h2></div><span class="badge neutral">${fmt(movements.length)} movimientos</span></div><div class="movement-list">${movementsHtml || '<p class="muted">Sin movimientos.</p>'}</div></section>`;
      };

      const downloadPdf = async () => {
        if (!lastCalculation) return;
        pdfButton.disabled = true;
        const originalText = pdfButton.textContent;
        pdfButton.textContent = 'Generando PDF...';
        try {
          const data = lastCalculation;
          const stock = data.stock_matches?.[0] || {};
          const summary = data.summary || {};
          const reception = data.last_reception || {};
          const stats = data.scan_stats || {};
          const timeline = groupByDay(data.movements || []);
          const movements = data.movements || [];
          const isPeriod = data.analysis_mode === 'period';
          const modeTitle = isPeriod ? 'Periodo explícito' : 'Última recepción';
          const pdf = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a4' });
          const pageWidth = pdf.internal.pageSize.getWidth();
          const pageHeight = pdf.internal.pageSize.getHeight();
          const margin = 34;
          const contentWidth = pageWidth - margin * 2;
          const dark = '#172033';
          const muted = '#64748b';
          const border = '#dbe3ef';
          const soft = '#f8fafc';
          const blue = '#2563eb';
          const green = '#166534';
          const amber = '#92400e';
          const amberBg = '#fffbeb';
          const red = '#991b1b';
          let y = margin;
          const footer = () => { pdf.setFont('helvetica', 'normal'); pdf.setFontSize(7.5); pdf.setTextColor(muted); pdf.text(`Generado ${new Date().toLocaleString('es-MX')} · ${plain(data.function_version)} · ${plain(data.scan_start_date || data.start_date)} a ${plain(data.end_date)} · ${modeTitle}`, margin, pageHeight - 18); pdf.text(`Página ${pdf.getNumberOfPages()}`, pageWidth - margin - 36, pageHeight - 18); };
          const newPage = () => { footer(); pdf.addPage(); y = margin; };
          const ensure = (height) => { if (y + height > pageHeight - 34) newPage(); };
          const title = (label, value) => { pdf.setFont('helvetica', 'bold'); pdf.setFontSize(7.5); pdf.setTextColor(muted); pdf.text(label.toUpperCase(), margin, y); y += 16; pdf.setFontSize(16); pdf.setTextColor(dark); pdf.text(plain(value), margin, y); y += 18; };
          const card = (x, yPos, w, h, label, value, note = '', mode = 'neutral') => {
            const fill = mode === 'dark' ? dark : mode === 'warning' ? amberBg : soft;
            const labelColor = mode === 'dark' ? '#cbd5e1' : muted;
            const valueColor = mode === 'dark' ? '#ffffff' : mode === 'warning' ? amber : dark;
            pdf.setDrawColor(mode === 'warning' ? '#f59e0b' : border); pdf.setFillColor(fill); pdf.roundedRect(x, yPos, w, h, 10, 10, 'FD');
            pdf.setFont('helvetica', 'bold'); pdf.setFontSize(7.2); pdf.setTextColor(labelColor); pdf.text(label.toUpperCase(), x + 11, yPos + 15);
            pdf.setFontSize(18); pdf.setTextColor(valueColor); pdf.text(plain(value), x + 11, yPos + 39, { maxWidth: w - 22 });
            if (note) { pdf.setFont('helvetica', 'normal'); pdf.setFontSize(7.4); pdf.setTextColor(labelColor); pdf.text(pdf.splitTextToSize(plain(note), w - 22), x + 11, yPos + 56); }
          };

          pdf.setFillColor(dark); pdf.roundedRect(margin, y, contentWidth, 72, 14, 14, 'F');
          pdf.setFont('helvetica', 'bold'); pdf.setFontSize(8); pdf.setTextColor('#cbd5e1'); pdf.text('CHINO REGALADO · BSALE LIVE · SELL-THROUGH V2', margin + 18, y + 20);
          pdf.setFontSize(24); pdf.setTextColor('#ffffff'); pdf.text(`Reporte por SKU · ${modeTitle}`, margin + 18, y + 48);
          pdf.setFont('helvetica', 'normal'); pdf.setFontSize(8.5); pdf.setTextColor('#cbd5e1'); pdf.text(`SKU ${plain(stock.sku || data.query)} · ${plain(stock.office_name)} · Variant ${plain(data.variant_ids?.join(', '))}`, pageWidth - margin - 330, y + 48, { maxWidth: 310 });
          y += 92;

          const kpiH = 74; const gap = 10; const kpiW = (contentWidth - gap * 4) / 5;
          card(margin, y, kpiW, kpiH, 'Sell-through venta', pct(summary.sell_through_pct), `${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)} de ${fmt(summary.piezas_recibidas_ultima_recepcion)} pzas`, 'dark');
          card(margin + (kpiW + gap), y, kpiW, kpiH, 'Recibidas', fmt(summary.piezas_recibidas_ultima_recepcion), isPeriod ? `${fmt(data.period_receptions?.length || 0)} recepciones` : `Recepción ${plain(reception.reception_id)}`);
          card(margin + (kpiW + gap) * 2, y, kpiW, kpiH, 'Vendidas netas', fmt(summary.piezas_netas_venta_desde_ultima_recepcion), `Devueltas ${fmt(summary.piezas_devueltas_desde_ultima_recepcion)}`);
          card(margin + (kpiW + gap) * 3, y, kpiW, kpiH, 'Ajuste stock', fmt(summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion), 'Salida no venta', summary.advertencia_salidas_superan_ultima_recepcion ? 'warning' : 'neutral');
          card(margin + (kpiW + gap) * 4, y, kpiW, kpiH, 'Stock live', fmt(summary.stock_actual), `Disponible ${fmt(summary.stock_disponible)}`);
          y += kpiH + 18;

          if (summary.advertencia_salidas_superan_ultima_recepcion) {
            pdf.setDrawColor('#f59e0b'); pdf.setFillColor(amberBg); pdf.roundedRect(margin, y, contentWidth, 54, 11, 11, 'FD');
            pdf.setFont('helvetica', 'bold'); pdf.setFontSize(8); pdf.setTextColor(amber); pdf.text('ADVERTENCIA DE TRAZABILIDAD', margin + 13, y + 17);
            pdf.setFont('helvetica', 'normal'); pdf.setFontSize(8.2); pdf.setTextColor(dark); pdf.text(pdf.splitTextToSize(plain(summary.nota_trazabilidad), contentWidth - 26), margin + 13, y + 35);
            y += 72;
          }

          pdf.setDrawColor(border); pdf.setFillColor('#ffffff'); pdf.roundedRect(margin, y, contentWidth, 76, 12, 12, 'FD');
          pdf.setFont('helvetica', 'bold'); pdf.setFontSize(8); pdf.setTextColor(muted); pdf.text(isPeriod ? 'PERIODO ANALIZADO' : 'ÚLTIMA RECEPCIÓN', margin + 14, y + 17);
          pdf.setFontSize(13); pdf.setTextColor(dark); pdf.text(isPeriod ? `${plain(data.start_date)} a ${plain(data.end_date)}` : `Recepción ${plain(reception.reception_id)} · ${plain(reception.movement_date)}`, margin + 14, y + 38);
          pdf.setFont('helvetica', 'normal'); pdf.setFontSize(8.5); pdf.setTextColor(dark);
          const contextText = isPeriod ? `Entradas ${fmt(summary.piezas_recibidas_ultima_recepcion)} · Ventas netas ${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)} · Ajuste stock ${fmt(summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion)} · Recepciones ${fmt(data.period_receptions?.length || 0)}` : `Piezas ${fmt(reception.quantity)} · Costo ${money(reception.cost)} · Stock al recibir ${fmt(reception.variant_stock)} · Doc ${plain(reception.document_number)} · Despacho ${plain(reception.internal_dispatch_id)}`;
          pdf.text(contextText, margin + 14, y + 57, { maxWidth: contentWidth - 28 });
          y += 98;

          title('Movimientos por día', isPeriod ? 'Recepciones, ventas, devoluciones y ajustes del periodo' : 'Movimientos desde la última recepción');
          const headers = ['Fecha', 'Recibidas', 'Vendidas', 'Devueltas', 'Ajuste', 'Salidas', 'Movs.', 'Barra'];
          const col = [0, 84, 166, 248, 332, 414, 494, 550];
          const drawHeader = () => { pdf.setFillColor('#eef2f7'); pdf.roundedRect(margin, y, contentWidth, 22, 8, 8, 'F'); pdf.setFont('helvetica', 'bold'); pdf.setFontSize(7.1); pdf.setTextColor(muted); headers.forEach((h, idx) => pdf.text(h.toUpperCase(), margin + col[idx] + 8, y + 14)); y += 28; };
          drawHeader();
          const maxOut = Math.max(1, ...timeline.map((row) => Math.max(num(row.received), num(row.stockOut))));
          for (const row of timeline) {
            ensure(26); pdf.setDrawColor('#e2e8f0'); pdf.line(margin, y + 24, margin + contentWidth, y + 24);
            pdf.setFont('helvetica', 'normal'); pdf.setFontSize(8.1); pdf.setTextColor(dark);
            [row.date, fmt(row.received), fmt(row.sold), fmt(row.returned), fmt(row.consumed), fmt(row.stockOut), fmt(row.movements)].forEach((value, idx) => pdf.text(plain(value), margin + col[idx] + 8, y + 16));
            const barX = margin + col[7] + 8; const barW = contentWidth - col[7] - 20; const fillW = Math.max(0, (Math.max(num(row.received), num(row.stockOut)) / maxOut) * barW);
            pdf.setFillColor('#e2e8f0'); pdf.roundedRect(barX, y + 9, barW, 8, 4, 4, 'F');
            if (fillW > 0) { pdf.setFillColor(row.consumed > 0 ? '#f59e0b' : blue); pdf.roundedRect(barX, y + 9, fillW, 8, 4, 4, 'F'); }
            y += 24;
          }

          y += 18; ensure(82); title('Cobertura revisada', 'Lecturas realizadas para construir el reporte');
          const coverageW = (contentWidth - 24) / 3;
          card(margin, y, coverageW, 58, 'Recepciones', fmt(stats.receptions?.receptions_seen), `Matches ${fmt(stats.receptions?.matches)}`);
          card(margin + coverageW + 12, y, coverageW, 58, 'Documentos', fmt(stats.documents?.documents_seen), `Líneas ${fmt(stats.documents?.details_seen)} · matches ${fmt(stats.documents?.matches)}`);
          card(margin + (coverageW + 12) * 2, y, coverageW, 58, 'Consumos', fmt(stats.consumptions?.consumptions_seen_in_date_range), `Líneas ${fmt(stats.consumptions?.details_seen)} · matches ${fmt(stats.consumptions?.matches)}`);

          if (movements.length) {
            newPage(); title('Detalle de movimientos', `Primeros ${Math.min(80, movements.length)} de ${movements.length} movimientos detectados`);
            const detailCols = [0, 92, 190, 270]; pdf.setFillColor('#eef2f7'); pdf.roundedRect(margin, y, contentWidth, 22, 8, 8, 'F');
            pdf.setFont('helvetica', 'bold'); pdf.setFontSize(7.2); pdf.setTextColor(muted); ['Fecha', 'Tipo', 'Cantidad', 'Referencia / nota'].forEach((h, idx) => pdf.text(h.toUpperCase(), margin + detailCols[idx] + 8, y + 14)); y += 28;
            for (const movement of movements.slice(0, 80)) {
              ensure(24); const type = movementLabel(movement); const qty = num(movement.quantity_signed ?? movement.quantity); const note = movement.document_number ? `Documento ${plain(movement.document_number)}` : movement.consumption_id ? `Consumo ${plain(movement.consumption_id)}` : plain(movement.note);
              pdf.setDrawColor('#e2e8f0'); pdf.line(margin, y + 22, margin + contentWidth, y + 22); pdf.setFont('helvetica', 'normal'); pdf.setFontSize(8.1); pdf.setTextColor(dark);
              pdf.text(plain(movement.movement_date), margin + detailCols[0] + 8, y + 15); pdf.text(type, margin + detailCols[1] + 8, y + 15); pdf.setFont('helvetica', 'bold'); pdf.setTextColor(qty < 0 ? red : type.includes('ajuste') ? amber : green); pdf.text(fmt(qty), margin + detailCols[2] + 8, y + 15); pdf.setFont('helvetica', 'normal'); pdf.setTextColor(muted); pdf.text(pdf.splitTextToSize(note, contentWidth - detailCols[3] - 16), margin + detailCols[3] + 8, y + 15); y += 22;
            }
          }
          footer(); pdf.save(`sell-through-${fileSafe(input.value.trim() || data.query)}-${ymd()}.pdf`);
        } finally { pdfButton.disabled = false; pdfButton.textContent = originalText; }
      };

      const sleep = (milliseconds) =>
        new Promise((resolve) => setTimeout(resolve, milliseconds));

      const normalizePeriodResult = (data) => {
        const summary = data?.summary || {};

        return {
          ...data,
          summary: {
            ...summary,
            piezas_recibidas_ultima_recepcion:
              summary.piezas_recibidas_periodo ??
              summary.piezas_recibidas_ultima_recepcion,
            piezas_vendidas_desde_ultima_recepcion:
              summary.piezas_vendidas_periodo ??
              summary.piezas_vendidas_desde_ultima_recepcion,
            piezas_devueltas_desde_ultima_recepcion:
              summary.piezas_devueltas_periodo ??
              summary.piezas_devueltas_desde_ultima_recepcion,
            piezas_netas_venta_desde_ultima_recepcion:
              summary.piezas_netas_venta_periodo ??
              summary.piezas_netas_venta_desde_ultima_recepcion,
            piezas_consumidas_ajuste_desde_ultima_recepcion:
              summary.piezas_consumidas_ajuste_periodo ??
              summary.piezas_consumidas_ajuste_desde_ultima_recepcion,
            piezas_consumidas_ajuste_stock_desde_ultima_recepcion:
              summary.piezas_consumidas_ajuste_stock_periodo ??
              summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion,
            piezas_salidas_stock_desde_ultima_recepcion:
              summary.piezas_salidas_stock_periodo ??
              summary.piezas_salidas_stock_desde_ultima_recepcion,
            salidas_vs_recepcion_pct:
              summary.salidas_vs_recepciones_periodo_pct ??
              summary.salidas_vs_recepcion_pct,
            advertencia_salidas_superan_ultima_recepcion:
              summary.advertencia_salidas_superan_recepciones_periodo ??
              summary.advertencia_salidas_superan_ultima_recepcion,
          },
        };
      };

      const invokePeriodRequest = async (action, request) => {
        const { data, error } = await supabase.functions.invoke(
          'request-sell-through-period-v1',
          {
            body: {
              action,
              query: request.query,
              office_id: request.officeId,
              period_start_date: request.startDate,
              period_end_date: request.endDate,
            },
          },
        );

        if (error) throw error;
        if (data?.ok === false || data?.error) {
          throw new Error(data?.error || 'No se pudo solicitar el cálculo.');
        }

        return data;
      };

      const getPeriodResult = async (request) => {
        const initial = await invokePeriodRequest('start', request);

        if (initial?.status === 'ready' && initial?.result) {
          return normalizePeriodResult(initial.result);
        }

        if (initial?.status !== 'processing') {
          throw new Error('La solicitud devolvió un estado inesperado.');
        }

        for (let attempt = 1; attempt <= 40; attempt += 1) {
          setStatus(
            `Procesando periodo en segundo plano... ${attempt * 15}s`,
          );

          await sleep(15_000);

          const check = await invokePeriodRequest('check', request);

          if (check?.status === 'ready' && check?.result) {
            return normalizePeriodResult(check.result);
          }
        }

        throw new Error(
          'El cálculo continúa en proceso. Intenta consultar nuevamente en unos minutos.',
        );
      };

      pdfButton.addEventListener('click', downloadPdf);

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const query = input.value.trim();
        const mode = modeSelect.value;

        if (!query) {
          return setStatus('Escribe un SKU o código de barras.');
        }

        if (
          mode === 'period' &&
          (!periodStart.value || !periodEnd.value)
        ) {
          return setStatus(
            'Selecciona fecha inicial y fecha final.',
          );
        }

        if (
          mode === 'period' &&
          periodStart.value > periodEnd.value
        ) {
          return setStatus(
            'La fecha inicial no puede ser mayor que la fecha final.',
          );
        }

        button.disabled = true;
        showPdf(false);
        result.innerHTML = '';

        try {
          let data;

          if (mode === 'period') {
            setStatus('Consultando resultado del periodo...');

            data = await getPeriodResult({
              query,
              officeId: Number(officeSelect.value),
              startDate: periodStart.value,
              endDate: periodEnd.value,
            });
          } else {
            setStatus('Buscando última recepción...');

            const body = {
              query,
              office_ids: [Number(officeSelect.value)],
              analysis_mode: mode,
              lookback_days: 365,
              max_reception_pages_per_office: 0,
              max_document_pages_per_day_type: 0,
              max_consumption_pages_per_office: 0,
              max_reception_details: 1000,
              max_document_details: 1000,
              max_consumption_details: 1000,
            };

            const response = await supabase.functions.invoke(
              'calculate-sell-through-live-v2',
              { body },
            );

            if (response.error) throw response.error;
            if (response.data?.error) {
              throw new Error(response.data.error);
            }

            data = response.data;
          }

          setStatus('');
          renderData(data);
        } catch (error) {
          setStatus('');
          renderError(error);
        } finally {
          button.disabled = false;
        }
      });
    </script>
  </body>
</html>

