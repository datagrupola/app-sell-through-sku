---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sell-through por SKU</title>
  </head>

  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Chino Regalado · Bsale Live + Supabase</p>
        <h1>Trazabilidad por SKU</h1>
        <p class="subtitle">
          Consulta stock actual en Bsale y trazabilidad histórica cargada en Supabase.
        </p>
      </section>

      <section class="panel">
        <form id="search-form" class="search-form">
          <label>
            SKU o código de barras
            <input id="search-input" type="text" placeholder="Ej. 610-PANT*28" autocomplete="off" required />
          </label>

          <label>
            Sucursal
            <select id="office-select">
              <option value="2">CHINO LAS AMERICAS</option>
              <option value="3">CHINO LA HUERTA</option>
              <option value="4">CHINO LEON CENTRO</option>
            </select>
          </label>

          <button id="search-button" type="submit">Consultar</button>
        </form>

        <div id="status" class="status"></div>
        <div id="result" class="result"></div>
      </section>
    </main>

    <script>
      import { supabase } from '../lib/supabase.js';

      const form = document.querySelector('#search-form');
      const input = document.querySelector('#search-input');
      const officeSelect = document.querySelector('#office-select');
      const button = document.querySelector('#search-button');
      const status = document.querySelector('#status');
      const result = document.querySelector('#result');

      const money = (value) => {
        return Number(value || 0).toLocaleString('es-MX', {
          style: 'currency',
          currency: 'MXN',
        });
      };

      const number = (value) => {
        return Number(value || 0).toLocaleString('es-MX', {
          maximumFractionDigits: 2,
        });
      };

      const text = (value) => {
        if (value === null || value === undefined || value === '') return '—';
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      };

      const dateText = (value) => {
        if (!value) return '—';
        return String(value).slice(0, 10);
      };

      const setStatus = (message) => {
        status.textContent = message;
      };

      const liveStockSection = (liveData, liveError) => {
        if (liveError) {
          return `
            <section class="section-card error-card">
              <div class="section-header">
                <div>
                  <p class="section-kicker">Bsale live</p>
                  <h2>Stock actual</h2>
                </div>
                <span class="badge danger">Error</span>
              </div>
              <p class="muted">${text(liveError.message || liveError)}</p>
            </section>
          `;
        }

        const matches = liveData?.stock_matches || [];

        if (!matches.length) {
          return `
            <section class="section-card">
              <div class="section-header">
                <div>
                  <p class="section-kicker">Bsale live</p>
                  <h2>Stock actual</h2>
                </div>
                <span class="badge neutral">No encontrado</span>
              </div>
              <p class="muted">
                No se encontró este SKU/código de barras en el stock actual indexado para la sucursal seleccionada.
              </p>
            </section>
          `;
        }

        return `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Bsale live</p>
                <h2>Stock actual</h2>
              </div>
              <span class="badge success">Encontrado</span>
            </div>

            <div class="summary-grid">
              ${matches
                .map(
                  (item) => `
                    <article class="card primary">
                      <span>SKU</span>
                      <strong>${text(item.sku)}</strong>
                      <small>${text(item.office_name)}</small>
                    </article>

                    <article class="card">
                      <span>Stock actual</span>
                      <strong>${number(item.quantity)}</strong>
                      <small>Disponible: ${number(item.quantity_available)}</small>
                    </article>

                    <article class="card">
                      <span>Reservado</span>
                      <strong>${number(item.quantity_reserved)}</strong>
                      <small>Live OK: ${item.live_ok ? 'sí' : 'no'}</small>
                    </article>

                    <article class="card">
                      <span>Código de barras</span>
                      <strong>${text(item.barcode)}</strong>
                      <small>Stock ID: ${text(item.stock_id)}</small>
                    </article>

                    <article class="card">
                      <span>Variant ID</span>
                      <strong>${text(item.variant_id)}</strong>
                      <small>Office ID: ${text(item.office_id)}</small>
                    </article>

                    <article class="card">
                      <span>Fuente</span>
                      <strong>${text(item.source)}</strong>
                      <small>Índice: ${dateText(item.index_synced_at)}</small>
                    </article>
                  `
                )
                .join('')}
            </div>
          </section>
        `;
      };

      const traceabilitySection = (traceData, traceError) => {
        if (traceError) {
          return `
            <section class="section-card error-card">
              <div class="section-header">
                <div>
                  <p class="section-kicker">Supabase histórico</p>
                  <h2>Trazabilidad</h2>
                </div>
                <span class="badge danger">Error</span>
              </div>
              <p class="muted">${text(traceError.message || traceError)}</p>
            </section>
          `;
        }

        const summary = traceData?.summary?.[0];
        const timeline = traceData?.timeline || [];

        if (!summary) {
          return `
            <section class="section-card">
              <div class="section-header">
                <div>
                  <p class="section-kicker">Supabase histórico</p>
                  <h2>Trazabilidad</h2>
                </div>
                <span class="badge warning">Sin historial</span>
              </div>
              <p class="muted">
                El SKU puede existir en Bsale live, pero no tiene recepción, venta, devolución o consumo histórico cargado en Supabase para esta consulta.
              </p>
            </section>
          `;
        }

        return `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Supabase histórico</p>
                <h2>Trazabilidad</h2>
              </div>
              <span class="badge success">Con historial</span>
            </div>

            <div class="summary-grid">
              <article class="card primary">
                <span>SKU trazado</span>
                <strong>${text(summary.sku_norm)}</strong>
                <small>${text(summary.sucursal)}</small>
              </article>

              <article class="card">
                <span>Estado</span>
                <strong>${text(summary.estado_trazabilidad)}</strong>
                <small>${text(summary.tipo_entrada)}</small>
              </article>

              <article class="card">
                <span>Sell-through</span>
                <strong>${summary.sell_through_pct === null ? '—' : `${number(summary.sell_through_pct)}%`}</strong>
                <small>Venta neta: ${money(summary.venta_neta)}</small>
              </article>

              <article class="card">
                <span>Piezas recibidas</span>
                <strong>${number(summary.piezas_recibidas_ultima_entrada)}</strong>
                <small>Última entrada: ${text(summary.ultima_entrada_fecha)}</small>
              </article>

              <article class="card">
                <span>Piezas vendidas</span>
                <strong>${number(summary.piezas_vendidas)}</strong>
                <small>Devueltas: ${number(summary.piezas_devueltas)}</small>
              </article>

              <article class="card">
                <span>Stock Supabase</span>
                <strong>${number(summary.stock_actual)}</strong>
                <small>Disponible: ${number(summary.stock_disponible)}</small>
              </article>
            </div>

            <div class="detail-card">
              <h3>Detalle histórico</h3>
              <dl>
                <div>
                  <dt>Código de barras</dt>
                  <dd>${text(summary.barcode_norm)}</dd>
                </div>
                <div>
                  <dt>Recepción</dt>
                  <dd>${text(summary.reception_id)}</dd>
                </div>
                <div>
                  <dt>Costo última entrada</dt>
                  <dd>${money(summary.costo_ultima_entrada)}</dd>
                </div>
                <div>
                  <dt>Variant recepción</dt>
                  <dd>${text(summary.last_reception_variant_id)}</dd>
                </div>
                <div>
                  <dt>Variant actual</dt>
                  <dd>${text(summary.current_variant_id)}</dd>
                </div>
                <div>
                  <dt>Movimientos consumo</dt>
                  <dd>${number(summary.movimientos_consumo)}</dd>
                </div>
              </dl>
            </div>

            <div class="timeline-card">
              <h3>Línea de tiempo</h3>
              ${
                timeline.length
                  ? `<div class="timeline">
                      ${timeline
                        .map(
                          (item) => `
                            <article class="movement">
                              <div class="movement-header">
                                <div>
                                  <strong>${text(item.movement_group)}</strong>
                                  <span>${text(item.movement_type)}</span>
                                </div>
                                <div class="movement-numbers">
                                  <span>${text(item.movement_date)}</span>
                                  <strong>${number(item.quantity_signed ?? item.quantity)}</strong>
                                </div>
                              </div>
                              <p>${text(item.note)}</p>
                            </article>
                          `
                        )
                        .join('')}
                    </div>`
                  : '<p class="muted">Sin movimientos disponibles.</p>'
              }
            </div>
          </section>
        `;
      };

      const renderResults = ({ liveData, liveError, traceData, traceError }) => {
        result.innerHTML = `
          ${liveStockSection(liveData, liveError)}
          ${traceabilitySection(traceData, traceError)}
        `;
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const searchValue = input.value.trim();
        const officeId = Number(officeSelect.value);

        if (!searchValue) {
          setStatus('Escribe un SKU o código de barras.');
          result.innerHTML = '';
          return;
        }

        button.disabled = true;
        result.innerHTML = '';
        setStatus('Consultando Bsale live y trazabilidad histórica...');

        const [liveResponse, traceResponse] = await Promise.all([
          supabase.functions.invoke('lookup-sku-live', {
            body: {
              query: searchValue,
              office_ids: [officeId],
            },
          }),
          supabase.rpc('get_sku_traceability_full', {
            search_value: searchValue,
            target_office_id: officeId,
          }),
        ]);

        button.disabled = false;
        setStatus('');

        renderResults({
          liveData: liveResponse.data,
          liveError: liveResponse.error,
          traceData: traceResponse.data,
          traceError: traceResponse.error,
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    color: #172033;
    background: #f4f6fb;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
  }

  .page {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 48px 0;
  }

  .hero {
    margin-bottom: 28px;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 8px;
    color: #64748b;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(32px, 6vw, 56px);
    line-height: 1;
  }

  h2,
  h3 {
    margin: 0;
  }

  .subtitle {
    max-width: 760px;
    margin: 16px 0 0;
    color: #64748b;
    font-size: 18px;
  }

  .panel,
  .section-card,
  .detail-card,
  .timeline-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
  }

  .panel {
    padding: 24px;
  }

  .search-form {
    display: grid;
    grid-template-columns: 1.4fr 1fr auto;
    gap: 16px;
    align-items: end;
  }

  label {
    display: grid;
    gap: 8px;
    color: #334155;
    font-size: 14px;
    font-weight: 800;
  }

  input,
  select,
  button {
    width: 100%;
    border-radius: 14px;
    border: 1px solid #cbd5e1;
    padding: 14px 16px;
    font: inherit;
  }

  button {
    border: 0;
    background: #172033;
    color: white;
    font-weight: 900;
    cursor: pointer;
  }

  button:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .status {
    margin-top: 18px;
    color: #64748b;
    font-weight: 800;
  }

  .result {
    display: grid;
    gap: 18px;
    margin-top: 24px;
  }

  .section-card {
    padding: 20px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .badge {
    display: inline-flex;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 12px;
    font-weight: 900;
    white-space: nowrap;
  }

  .badge.success {
    background: #dcfce7;
    color: #166534;
  }

  .badge.warning {
    background: #fef3c7;
    color: #92400e;
  }

  .badge.neutral {
    background: #e2e8f0;
    color: #334155;
  }

  .badge.danger {
    background: #fee2e2;
    color: #991b1b;
  }

  .error-card {
    border-color: #fecaca;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .card {
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    padding: 18px;
    background: #f8fafc;
  }

  .card span {
    display: block;
    color: #64748b;
    font-size: 13px;
    font-weight: 800;
  }

  .card strong {
    display: block;
    margin-top: 8px;
    font-size: 24px;
    overflow-wrap: anywhere;
  }

  .card small {
    display: block;
    margin-top: 6px;
    color: #64748b;
  }

  .primary {
    background: #172033;
    color: white;
  }

  .primary span,
  .primary small {
    color: #dbe4f0;
  }

  .detail-card,
  .timeline-card {
    margin-top: 16px;
    padding: 18px;
    box-shadow: none;
    background: #f8fafc;
  }

  .detail-card h3,
  .timeline-card h3 {
    margin-bottom: 16px;
    font-size: 20px;
  }

  dl {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin: 0;
  }

  dt {
    color: #64748b;
    font-size: 13px;
    font-weight: 800;
  }

  dd {
    margin: 4px 0 0;
    font-weight: 900;
    overflow-wrap: anywhere;
  }

  .timeline {
    display: grid;
    gap: 12px;
  }

  .movement {
    display: grid;
    gap: 10px;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 14px;
    background: white;
  }

  .movement-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .movement-header span {
    display: block;
    margin-top: 4px;
    color: #64748b;
  }

  .movement-numbers {
    text-align: right;
  }

  .movement p {
    margin: 0;
    color: #64748b;
  }

  .muted {
    margin: 0;
    color: #64748b;
    line-height: 1.55;
  }

  @media (max-width: 820px) {
    .search-form,
    .summary-grid,
    dl {
      grid-template-columns: 1fr;
    }

    .section-header,
    .movement-header {
      display: grid;
    }

    .movement-numbers {
      text-align: left;
    }
  }
</style>
