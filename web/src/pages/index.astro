---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sell-through live por SKU</title>
  </head>

  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Chino Regalado · Bsale live · v2</p>
        <h1>Sell-through live por SKU</h1>
        <p class="subtitle">
          Calcula última recepción, ventas, devoluciones, consumos/ajustes y stock actual directamente desde Bsale.
        </p>
      </section>

      <section class="panel">
        <form id="search-form" class="search-form">
          <label>
            SKU o código de barras
            <input id="search-input" type="text" placeholder="Ej. ROPACR" autocomplete="off" required />
          </label>

          <label>
            Sucursal
            <select id="office-select">
              <option value="2">CHINO LAS AMERICAS</option>
              <option value="3">CHINO LA HUERTA</option>
              <option value="4">CHINO LEON CENTRO</option>
            </select>
          </label>

          <label>
            Buscar recepción en
            <select id="lookback-select">
              <option value="10">Últimos 10 días</option>
              <option value="30">Últimos 30 días</option>
              <option value="90">Últimos 90 días</option>
              <option value="180">Últimos 180 días</option>
              <option value="365" selected>Últimos 365 días</option>
            </select>
          </label>

          <button id="search-button" type="submit">Calcular</button>
        </form>

        <div class="actions-row">
          <div id="status" class="status"></div>
          <button id="pdf-button" class="secondary-button" type="button" hidden>
            Descargar PDF
          </button>
        </div>

        <div id="result" class="result"></div>
      </section>
    </main>

    <script>
      import { supabase } from '../lib/supabase.js';
      import { jsPDF } from 'jspdf';

      const form = document.querySelector('#search-form');
      const input = document.querySelector('#search-input');
      const officeSelect = document.querySelector('#office-select');
      const lookbackSelect = document.querySelector('#lookback-select');
      const button = document.querySelector('#search-button');
      const pdfButton = document.querySelector('#pdf-button');
      const status = document.querySelector('#status');
      const result = document.querySelector('#result');

      let lastCalculation = null;

      const numeric = (value) => {
        const parsed = Number(value ?? 0);
        return Number.isFinite(parsed) ? parsed : 0;
      };

      const number = (value) => {
        return Number(value || 0).toLocaleString('es-MX', { maximumFractionDigits: 2 });
      };

      const money = (value) => {
        return Number(value || 0).toLocaleString('es-MX', {
          style: 'currency',
          currency: 'MXN',
        });
      };

      const pct = (value) => {
        if (value === null || value === undefined || value === '') return '—';
        return `${number(value)}%`;
      };

      const text = (value) => {
        if (value === null || value === undefined || value === '') return '—';
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      };

      const clamp = (value, min, max) => Math.max(min, Math.min(max, Number(value || 0)));

      const setStatus = (message) => {
        status.textContent = message;
      };

      const setPdfAvailable = (available) => {
        pdfButton.hidden = !available;
      };

      const fileSafe = (value) => {
        return String(value || 'sku')
          .trim()
          .replace(/[^a-z0-9-_]+/gi, '-')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '')
          .toLowerCase();
      };

      const sellThroughLevel = (value) => {
        const numericValue = Number(value || 0);
        if (numericValue >= 80) return 'Alto';
        if (numericValue >= 50) return 'Medio';
        if (numericValue >= 20) return 'Bajo';
        return 'Inicial';
      };

      const buildDailyTimeline = (movements = []) => {
        const byDate = new Map();

        for (const item of movements) {
          const group = item?.movement_group;
          const date = item?.movement_date || 'Sin fecha';
          const current = byDate.get(date) || {
            date,
            sold: 0,
            returned: 0,
            consumed: 0,
            stockOut: 0,
            netSold: 0,
            movements: 0,
          };

          const qty = numeric(item.quantity);

          if (group === 'VENTA') current.sold += qty;
          if (group === 'DEVOLUCION') current.returned += qty;
          if (group === 'CONSUMO_AJUSTE') current.consumed += qty;

          current.netSold = current.sold - current.returned;
          current.stockOut = current.netSold + current.consumed;
          current.movements += 1;
          byDate.set(date, current);
        }

        return Array.from(byDate.values()).sort((a, b) => String(a.date).localeCompare(String(b.date)));
      };

      const movementTypeLabel = (movement) => {
        if (movement.movement_group === 'ENTRADA') return 'Recepción';
        if (movement.movement_group === 'VENTA') return 'Venta';
        if (movement.movement_group === 'DEVOLUCION') return 'Devolución';
        if (movement.movement_group === 'CONSUMO_AJUSTE') return 'Consumo / ajuste';
        return 'Movimiento';
      };

      const movementClass = (movement) => {
        if (movement.movement_group === 'ENTRADA') return 'in';
        if (movement.movement_group === 'CONSUMO_AJUSTE') return 'adjust';
        if (movement.movement_group === 'DEVOLUCION') return 'return';
        return 'sale';
      };

      const renderNotFound = (data) => {
        lastCalculation = data;
        setPdfAvailable(false);
        result.innerHTML = `
          <section class="section-card error-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Resultado</p>
                <h2>SKU no encontrado</h2>
              </div>
              <span class="badge danger">Sin coincidencia</span>
            </div>
            <p class="muted">
              No se encontró variant_id para <strong>${text(data?.query || input.value)}</strong>
              en el índice técnico de Supabase.
            </p>
          </section>
        `;
      };

      const renderNoReception = (data) => {
        lastCalculation = data;
        const stock = data.stock_matches?.[0];
        const summary = data.summary || {};
        setPdfAvailable(false);

        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Bsale live</p>
                <h2>SKU encontrado, sin recepción en rango</h2>
              </div>
              <span class="badge warning">Sin última recepción</span>
            </div>

            <div class="summary-grid compact">
              <article class="card primary">
                <span>SKU</span>
                <strong>${text(stock?.sku || data.query)}</strong>
                <small>${text(stock?.office_name)}</small>
              </article>
              <article class="card">
                <span>Stock actual</span>
                <strong>${number(summary.stock_actual)}</strong>
                <small>Disponible: ${number(summary.stock_disponible)}</small>
              </article>
              <article class="card">
                <span>Variant ID</span>
                <strong>${text(data.variant_ids?.join(', '))}</strong>
                <small>Rango: ${text(data.start_date)} a ${text(data.end_date)}</small>
              </article>
            </div>

            <p class="muted block-note">
              El SKU existe, pero no se encontró recepción dentro del rango consultado.
              Amplía el rango de búsqueda y vuelve a calcular.
            </p>
          </section>
        `;
      };

      const renderError = (error) => {
        setPdfAvailable(false);
        result.innerHTML = `
          <section class="section-card error-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Error</p>
                <h2>No se pudo calcular</h2>
              </div>
              <span class="badge danger">Error</span>
            </div>
            <p class="muted">${text(error?.message || error)}</p>
          </section>
        `;
      };

      const renderData = (data) => {
        lastCalculation = data;

        if (!data?.found) {
          renderNotFound(data);
          return;
        }

        if (!data?.sell_through_found) {
          renderNoReception(data);
          return;
        }

        const stock = data.stock_matches?.[0] || {};
        const summary = data.summary || {};
        const reception = data.last_reception || {};
        const scanStats = data.scan_stats || {};
        const movements = data.movements || [];
        const timeline = buildDailyTimeline(movements);
        const sellThroughValue = numeric(summary.sell_through_pct);
        const sellThroughClamped = clamp(sellThroughValue, 0, 100);
        const sellThroughStatus = sellThroughLevel(sellThroughValue);
        const showWarning = summary.advertencia_salidas_superan_ultima_recepcion === true;
        const maxOut = Math.max(1, ...timeline.map((row) => numeric(row.stockOut)));

        setPdfAvailable(true);

        const warningHtml = showWarning
          ? `<section class="section-card warning-card">
              <div class="section-header tight">
                <div>
                  <p class="section-kicker">Advertencia de trazabilidad</p>
                  <h2>Las salidas superan la última recepción</h2>
                </div>
                <span class="badge warning">Revisar lote</span>
              </div>
              <p class="muted block-note">${text(summary.nota_trazabilidad)}</p>
            </section>`
          : '';

        const timelineHtml = timeline.length
          ? `<div class="timeline">
              ${timeline
                .map((row) => {
                  const width = row.stockOut > 0 ? Math.max(4, (row.stockOut / maxOut) * 100) : 0;
                  return `
                    <article class="timeline-day">
                      <div class="timeline-date">
                        <strong>${text(row.date)}</strong>
                        <small>${number(row.movements)} movimientos</small>
                      </div>
                      <div class="timeline-main">
                        <div class="bar-shell"><div class="bar" style="width:${width}%"></div></div>
                        <div class="pill-row">
                          <span><strong>${number(row.sold)}</strong> vendidas</span>
                          <span><strong>${number(row.returned)}</strong> devueltas</span>
                          <span><strong>${number(row.consumed)}</strong> ajuste/consumo</span>
                          <span><strong>${number(row.stockOut)}</strong> salidas stock</span>
                        </div>
                      </div>
                    </article>
                  `;
                })
                .join('')}
            </div>`
          : `<p class="muted block-note">No hay movimientos posteriores a la última recepción.</p>`;

        const movementsHtml = movements
          .slice(0, 80)
          .map((movement) => `
            <article class="movement-row ${movementClass(movement)}">
              <div>
                <strong>${text(movementTypeLabel(movement))}</strong>
                <small>${text(movement.movement_date)} · ${text(movement.note)}</small>
              </div>
              <div class="movement-qty">
                <strong>${number(movement.quantity_signed ?? movement.quantity)}</strong>
                <small>piezas</small>
              </div>
            </article>
          `)
          .join('');

        result.innerHTML = `
          ${warningHtml}

          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Resultado live</p>
                <h2>${text(stock.sku || data.query)}</h2>
              </div>
              <span class="badge success">${text(data.function_version || 'v2')}</span>
            </div>

            <div class="result-layout">
              <article class="sellthrough-panel">
                <div class="gauge" style="--value:${sellThroughClamped};">
                  <div class="gauge-inner">
                    <strong>${pct(summary.sell_through_pct)}</strong>
                    <span>${text(sellThroughStatus)}</span>
                  </div>
                </div>

                <div>
                  <p class="metric-label">Sell-through por venta</p>
                  <p class="metric-help">
                    ${number(summary.piezas_netas_venta_desde_ultima_recepcion)} piezas netas vendidas de
                    ${number(summary.piezas_recibidas_ultima_recepcion)} recibidas.
                  </p>
                </div>
              </article>

              <div class="summary-grid compact">
                <article class="card">
                  <span>Recibidas</span>
                  <strong>${number(summary.piezas_recibidas_ultima_recepcion)}</strong>
                  <small>Recepción ${text(reception.reception_id)} · ${text(reception.movement_date)}</small>
                </article>
                <article class="card">
                  <span>Vendidas netas</span>
                  <strong>${number(summary.piezas_netas_venta_desde_ultima_recepcion)}</strong>
                  <small>Vendidas: ${number(summary.piezas_vendidas_desde_ultima_recepcion)} · Devueltas: ${number(summary.piezas_devueltas_desde_ultima_recepcion)}</small>
                </article>
                <article class="card ${showWarning ? 'warning-soft' : ''}">
                  <span>Consumo / ajuste</span>
                  <strong>${number(summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion)}</strong>
                  <small>Salidas no venta que afectaron stock</small>
                </article>
                <article class="card ${showWarning ? 'warning-soft' : ''}">
                  <span>Salidas stock</span>
                  <strong>${number(summary.piezas_salidas_stock_desde_ultima_recepcion)}</strong>
                  <small>${pct(summary.salidas_vs_recepcion_pct)} de la última recepción</small>
                </article>
                <article class="card">
                  <span>Stock actual</span>
                  <strong>${number(summary.stock_actual)}</strong>
                  <small>Disponible: ${number(summary.stock_disponible)}</small>
                </article>
                <article class="card">
                  <span>Sucursal</span>
                  <strong>${text(stock.office_name)}</strong>
                  <small>Variant ID ${text(data.variant_ids?.join(', '))}</small>
                </article>
              </div>
            </div>
          </section>

          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Última recepción</p>
                <h2>Recepción ${text(reception.reception_id)}</h2>
              </div>
              <span class="badge neutral">${text(reception.movement_type)}</span>
            </div>

            <dl class="detail-grid">
              <div><dt>Fecha</dt><dd>${text(reception.movement_date)}</dd></div>
              <div><dt>Piezas</dt><dd>${number(reception.quantity)}</dd></div>
              <div><dt>Costo</dt><dd>${money(reception.cost)}</dd></div>
              <div><dt>Stock al recibir</dt><dd>${number(reception.variant_stock)}</dd></div>
              <div><dt>Documento</dt><dd>${text(reception.document_number)}</dd></div>
              <div><dt>Despacho interno</dt><dd>${text(reception.internal_dispatch_id)}</dd></div>
              <div class="wide"><dt>Nota</dt><dd>${text(reception.note)}</dd></div>
            </dl>
          </section>

          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Movimientos por día</p>
                <h2>Ventas, devoluciones y ajustes desde la recepción</h2>
              </div>
              <span class="badge neutral">${number(timeline.length)} días</span>
            </div>
            ${timelineHtml}
          </section>

          <section class="section-card muted-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Cobertura revisada</p>
                <h2>Qué leyó la función en Bsale</h2>
              </div>
              <span class="badge neutral">Diagnóstico</span>
            </div>

            <div class="coverage-grid">
              <article class="coverage-item">
                <span>Rango recepción</span>
                <strong>${text(data.start_date)} a ${text(data.end_date)}</strong>
                <p>Estrategia: ${text(data.diagnostic?.reception_order_strategy)}</p>
              </article>
              <article class="coverage-item">
                <span>Recepciones revisadas</span>
                <strong>${number(scanStats.receptions?.receptions_seen)}</strong>
                <p>Coincidencias: ${number(scanStats.receptions?.matches)}</p>
              </article>
              <article class="coverage-item">
                <span>Documentos revisados</span>
                <strong>${number(scanStats.documents?.documents_seen)}</strong>
                <p>Líneas: ${number(scanStats.documents?.details_seen)} · matches: ${number(scanStats.documents?.matches)}</p>
              </article>
              <article class="coverage-item">
                <span>Consumos revisados</span>
                <strong>${number(scanStats.consumptions?.consumptions_seen_in_date_range)}</strong>
                <p>Líneas: ${number(scanStats.consumptions?.details_seen)} · matches: ${number(scanStats.consumptions?.matches)}</p>
              </article>
              <article class="coverage-item">
                <span>Scan desde</span>
                <strong>${text(data.scan_start_date)}</strong>
                <p>Desde la fecha de la última recepción encontrada.</p>
              </article>
              <article class="coverage-item">
                <span>Errores API</span>
                <strong>${number((scanStats.receptions?.detail_errors || []).length + (scanStats.documents?.detail_errors || []).length + (scanStats.consumptions?.detail_errors || []).length)}</strong>
                <p>Errores de detalle acumulados en Bsale.</p>
              </article>
            </div>
          </section>

          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Detalle</p>
                <h2>Movimientos detectados</h2>
              </div>
              <span class="badge neutral">${number(movements.length)} movimientos</span>
            </div>

            <div class="movement-list">
              ${movementsHtml || '<p class="muted">Sin movimientos.</p>'}
            </div>
          </section>
        `;
      };

      const downloadPdf = async () => {
        if (!lastCalculation) return;

        pdfButton.disabled = true;
        const originalText = pdfButton.textContent;
        pdfButton.textContent = 'Generando PDF...';

        try {
          const data = lastCalculation;
          const stock = data.stock_matches?.[0] || {};
          const summary = data.summary || {};
          const reception = data.last_reception || {};
          const timeline = buildDailyTimeline(data.movements || []);
          const pdf = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a4' });
          const margin = 36;
          let y = margin;

          const line = (label, value) => {
            pdf.setFont('helvetica', 'bold');
            pdf.text(label, margin, y);
            pdf.setFont('helvetica', 'normal');
            pdf.text(String(value ?? '—'), margin + 190, y);
            y += 18;
          };

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(22);
          pdf.text('Reporte sell-through por SKU', margin, y);
          y += 28;
          pdf.setFontSize(10);
          pdf.setFont('helvetica', 'normal');
          pdf.text(`SKU: ${stock.sku || data.query} · Sucursal: ${stock.office_name || '—'} · Generado: ${new Date().toLocaleString('es-MX')}`, margin, y);
          y += 28;

          line('Última recepción', `${reception.reception_id || '—'} · ${reception.movement_date || '—'}`);
          line('Piezas recibidas', number(summary.piezas_recibidas_ultima_recepcion));
          line('Piezas vendidas netas', number(summary.piezas_netas_venta_desde_ultima_recepcion));
          line('Consumos / ajustes stock', number(summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion));
          line('Salidas stock desde recepción', number(summary.piezas_salidas_stock_desde_ultima_recepcion));
          line('Stock actual', number(summary.stock_actual));
          line('Sell-through venta', pct(summary.sell_through_pct));
          line('Salidas vs recepción', pct(summary.salidas_vs_recepcion_pct));

          if (summary.nota_trazabilidad) {
            y += 8;
            pdf.setFont('helvetica', 'bold');
            pdf.text('Advertencia', margin, y);
            y += 16;
            pdf.setFont('helvetica', 'normal');
            pdf.text(String(summary.nota_trazabilidad), margin, y, { maxWidth: 760 });
            y += 34;
          }

          y += 12;
          pdf.setFont('helvetica', 'bold');
          pdf.text('Movimientos por día', margin, y);
          y += 18;
          pdf.setFont('helvetica', 'normal');

          for (const row of timeline) {
            if (y > 540) {
              pdf.addPage();
              y = margin;
            }
            pdf.text(
              `${row.date} · vendidas ${number(row.sold)} · devueltas ${number(row.returned)} · ajuste ${number(row.consumed)} · salidas stock ${number(row.stockOut)}`,
              margin,
              y,
            );
            y += 16;
          }

          const sku = input.value.trim() || 'sku';
          const date = new Date().toISOString().slice(0, 10);
          pdf.save(`sell-through-${fileSafe(sku)}-${date}.pdf`);
        } finally {
          pdfButton.disabled = false;
          pdfButton.textContent = originalText;
        }
      };

      pdfButton.addEventListener('click', downloadPdf);

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const searchValue = input.value.trim();
        const officeId = Number(officeSelect.value);
        const lookbackDays = Number(lookbackSelect.value);

        if (!searchValue) {
          setStatus('Escribe un SKU o código de barras.');
          result.innerHTML = '';
          return;
        }

        button.disabled = true;
        lastCalculation = null;
        setPdfAvailable(false);
        result.innerHTML = '';
        setStatus('Calculando sell-through live v2 desde Bsale...');

        const { data, error } = await supabase.functions.invoke('calculate-sell-through-live-v2', {
          body: {
            query: searchValue,
            office_ids: [officeId],
            lookback_days: lookbackDays,
            max_reception_pages_per_office: 0,
            max_document_pages_per_day_type: 0,
            max_consumption_pages_per_office: 0,
            max_reception_details: 1000,
            max_document_details: 1000,
            max_consumption_details: 1000,
          },
        });

        button.disabled = false;
        setStatus('');

        if (error) {
          renderError(error);
          return;
        }

        if (data?.error) {
          renderError(data.error);
          return;
        }

        renderData(data);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    color: #172033;
    background:
      radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 32rem),
      #f4f6fb;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
  }

  .page {
    width: min(1220px, calc(100% - 56px));
    margin: 0 auto;
    padding: 34px 0 48px;
  }

  .hero {
    margin-bottom: 22px;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 8px;
    color: #64748b;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(38px, 4vw, 58px);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  h2,
  h3 {
    margin: 0;
    letter-spacing: -0.025em;
  }

  h2 {
    font-size: 22px;
  }

  h3 {
    font-size: 18px;
  }

  .subtitle {
    max-width: 820px;
    margin: 12px 0 0;
    color: #64748b;
    font-size: 16px;
    line-height: 1.45;
  }

  .panel,
  .section-card {
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid #dbe3ef;
    box-shadow: 0 24px 80px rgba(15, 23, 42, 0.08);
  }

  .panel {
    border-radius: 28px;
    padding: 18px;
  }

