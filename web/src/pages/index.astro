---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sell-through live por SKU</title>
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Chino Regalado · Bsale live · v2</p>
        <h1>Sell-through live por SKU</h1>
        <p class="subtitle">Analiza movimientos por última recepción o por periodo explícito. La operación documental cierra hasta ayer.</p>
      </section>
      <section class="panel">
        <form id="search-form" class="search-form">
          <label>SKU o código de barras<input id="search-input" type="text" placeholder="Ej. ROPACR" autocomplete="off" required /></label>
          <label>Sucursal<select id="office-select"><option value="2">CHINO LAS AMERICAS</option><option value="3">CHINO LA HUERTA</option><option value="4">CHINO LEON CENTRO</option></select></label>
          <label>Buscar recepción en<select id="mode-select"><option value="last_reception" selected>Última recepción</option><option value="period">Periodo</option></select></label>
          <label class="period-field" hidden>Fecha inicial<input id="period-start" type="date" /></label>
          <label class="period-field" hidden>Fecha final<input id="period-end" type="date" /></label>
          <button id="search-button" type="submit">Calcular</button>
        </form>
        <div class="actions-row"><div id="status" class="status"></div><button id="pdf-button" class="secondary-button" type="button" hidden>Descargar PDF</button></div>
        <div id="result" class="result"></div>
      </section>
    </main>

    <script>
      import { supabase } from '../lib/supabase.js';
      import { jsPDF } from 'jspdf';

      const form = document.querySelector('#search-form');
      const input = document.querySelector('#search-input');
      const officeSelect = document.querySelector('#office-select');
      const modeSelect = document.querySelector('#mode-select');
      const periodFields = Array.from(document.querySelectorAll('.period-field'));
      const periodStart = document.querySelector('#period-start');
      const periodEnd = document.querySelector('#period-end');
      const button = document.querySelector('#search-button');
      const pdfButton = document.querySelector('#pdf-button');
      const status = document.querySelector('#status');
      const result = document.querySelector('#result');
      let lastCalculation = null;

      const num = (v) => { const p = Number(v ?? 0); return Number.isFinite(p) ? p : 0; };
      const fmt = (v) => num(v).toLocaleString('es-MX', { maximumFractionDigits: 2 });
      const money = (v) => num(v).toLocaleString('es-MX', { style: 'currency', currency: 'MXN' });
      const pct = (v) => v === null || v === undefined || v === '' ? '—' : `${fmt(v)}%`;
      const esc = (v) => String(v ?? '—').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;');
      const plain = (v) => String(v ?? '—');
      const ymd = () => new Date().toISOString().slice(0, 10);
      const yesterday = () => { const d = new Date(); d.setUTCDate(d.getUTCDate() - 1); return d.toISOString().slice(0, 10); };
      const daysAgo = (days) => { const d = new Date(); d.setUTCDate(d.getUTCDate() - days); return d.toISOString().slice(0, 10); };
      const daysSinceDate = (value) => {
        if (!value) return null;

        const receptionDate = Date.parse(`${value}T00:00:00Z`);

        if (!Number.isFinite(receptionDate)) return null;

        const now = new Date();
        const todayUtc = Date.UTC(
          now.getUTCFullYear(),
          now.getUTCMonth(),
          now.getUTCDate(),
        );

        return Math.max(
          0,
          Math.floor((todayUtc - receptionDate) / 86_400_000),
        );
      };
      const setStatus = (message) => { status.textContent = message; };
      const showPdf = (value) => { pdfButton.hidden = !value; };
      const fileSafe = (v) => String(v || 'sku').trim().replace(/[^a-z0-9-_]+/gi, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').toLowerCase();

      const updateModeUi = () => {
        const isPeriod = modeSelect.value === 'period';
        periodFields.forEach((field) => { field.hidden = !isPeriod; });
        form.classList.toggle('period-mode', isPeriod);
        if (isPeriod) {
          if (!periodStart.value) periodStart.value = daysAgo(30);
          if (!periodEnd.value) periodEnd.value = yesterday();
          periodEnd.max = yesterday();
        }
      };
      modeSelect.addEventListener('change', updateModeUi);
      updateModeUi();

      const groupByDay = (movements = []) => {
        const map = new Map();
        for (const movement of movements) {
          const date = movement.movement_date || 'Sin fecha';
          const row = map.get(date) || { date, received: 0, sold: 0, returned: 0, consumed: 0, stockOut: 0, movements: 0 };
          const qty = num(movement.quantity);
          if (movement.movement_group === 'ENTRADA') row.received += qty;
          if (movement.movement_group === 'VENTA') row.sold += qty;
          if (movement.movement_group === 'DEVOLUCION') row.returned += qty;
          if (movement.movement_group === 'CONSUMO_AJUSTE') row.consumed += qty;
          row.stockOut = row.sold - row.returned + row.consumed;
          row.movements += 1;
          map.set(date, row);
        }
        return Array.from(map.values()).sort((a, b) => String(a.date).localeCompare(String(b.date)));
      };
      const movementLabel = (m) => m.movement_group === 'ENTRADA' ? 'Recepción' : m.movement_group === 'VENTA' ? 'Venta' : m.movement_group === 'DEVOLUCION' ? 'Devolución' : m.movement_group === 'CONSUMO_AJUSTE' ? 'Consumo / ajuste' : 'Movimiento';
      const movementClass = (m) => m.movement_group === 'ENTRADA' ? 'in' : m.movement_group === 'CONSUMO_AJUSTE' ? 'adjust' : m.movement_group === 'DEVOLUCION' ? 'return' : 'sale';

      const renderError = (message) => { showPdf(false); result.innerHTML = `<section class="section-card error-card"><div class="section-header"><div><p class="section-kicker">Error</p><h2>No se pudo calcular</h2></div><span class="badge danger">Error</span></div><p class="muted">${esc(message?.message || message)}</p></section>`; };
      const renderNoReception = (data) => {
        const stock = data.stock_matches?.[0] || {}; const summary = data.summary || {}; showPdf(false);
        result.innerHTML = `<section class="section-card"><div class="section-header"><div><p class="section-kicker">Resultado</p><h2>SKU encontrado, sin recepción</h2></div><span class="badge warning">Sin entrada</span></div><div class="summary-grid compact"><article class="card primary"><span>SKU</span><strong>${esc(stock.sku || data.query)}</strong><small>${esc(stock.office_name)}</small></article><article class="card"><span>Stock actual Bsale live</span><strong>${fmt(summary.stock_actual)}</strong><small>Disponible: ${fmt(summary.stock_disponible)}</small></article><article class="card"><span>Rango</span><strong>${esc(data.start_date)} a ${esc(data.end_date)}</strong><small>Variant ID ${esc(data.variant_ids?.join(', '))}</small></article></div></section>`;
      };

      const renderData = (data) => {
        lastCalculation = data;
        if (!data?.found) return renderError(data?.message || 'SKU no encontrado.');
        if (!data?.sell_through_found) return renderNoReception(data);
        showPdf(true);
        const isPeriod = data.analysis_mode === 'period';
        const stock = data.stock_matches?.[0] || {};
        const summary = data.summary || {};
        const reception = data.last_reception || {};
        const daysSinceLastReception = daysSinceDate(
          reception.movement_date,
        );

        const hasPriorStock = Boolean(
          summary.advertencia_salidas_superan_ultima_recepcion,
        );
        const priorStockMinimum = Math.max(
          0,
          num(summary.piezas_salidas_stock_desde_ultima_recepcion) -
            num(summary.piezas_recibidas_ultima_recepcion),
        );
        const receptionAgeDanger =
          !hasPriorStock &&
          daysSinceLastReception !== null &&
          daysSinceLastReception >= 35 &&
          num(summary.sell_through_pct) < 35;

        const stats = data.scan_stats || {};
        const movements = data.movements || [];
        const timeline = groupByDay(movements);
        const modeTitle = isPeriod ? 'Periodo explícito' : 'Última recepción';
        const receivedNote = isPeriod ? `${fmt(data.period_receptions?.length || 0)} recepciones dentro del periodo` : `Recepción ${esc(reception.reception_id)} · ${esc(reception.movement_date)}`;
        const warning = hasPriorStock ? `<section class="section-card warning-card"><div class="section-header tight"><div><p class="section-kicker">Contexto de inventario</p><h2>Inventario previo detectado</h2></div><span class="badge warning">Stock previo</span></div><p class="muted block-note">${isPeriod ? 'Las salidas del periodo superan las entradas registradas en ese rango.' : 'Las salidas desde la última recepción superan las piezas recibidas.'} La sucursal ya contaba con existencias de este SKU, por lo que las ventas no pueden atribuirse exclusivamente a ${isPeriod ? 'las entradas del periodo' : 'la última recepción'}. Al menos ${fmt(priorStockMinimum)} piezas de las salidas requirieron inventario previo.</p></section>` : '';
        const timelineHtml = timeline.map((row) => `<article class="timeline-day"><div class="timeline-date"><strong>${esc(row.date)}</strong><small>${fmt(row.movements)} movimientos</small></div><div class="pill-row"><span><strong>${fmt(row.received)}</strong> recibidas</span><span><strong>${fmt(row.sold)}</strong> vendidas</span><span><strong>${fmt(row.returned)}</strong> devueltas</span><span><strong>${fmt(row.consumed)}</strong> ajustes</span><span><strong>${fmt(row.stockOut)}</strong> salidas stock</span></div></article>`).join('');
        const movementsHtml = movements.slice(0, 120).map((movement) => `<article class="movement-row ${movementClass(movement)}"><div><strong>${esc(movementLabel(movement))}</strong><small>${esc(movement.movement_date)} · ${esc(movement.note)}</small></div><div class="movement-qty"><strong>${fmt(movement.quantity_signed ?? movement.quantity)}</strong><small>piezas</small></div></article>`).join('');
        const context = isPeriod
          ? `<section class="section-card"><div class="section-header"><div><p class="section-kicker">Periodo analizado</p><h2>${esc(data.start_date)} a ${esc(data.end_date)}</h2></div><span class="badge neutral">Periodo</span></div><dl class="detail-grid"><div><dt>Fecha inicial</dt><dd>${esc(data.start_date)}</dd></div><div><dt>Fecha final</dt><dd>${esc(data.end_date)}</dd></div><div><dt>Recepciones</dt><dd>${fmt(data.period_receptions?.length || 0)}</dd></div><div><dt>Piezas recibidas</dt><dd>${fmt(summary.piezas_recibidas_periodo ?? summary.piezas_recibidas_ultima_recepcion)}</dd></div><div><dt>Vendidas netas</dt><dd>${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)}</dd></div><div><dt>Ajustes stock</dt><dd>${fmt(summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion)}</dd></div></dl></section>`
          : `<section class="section-card"><div class="section-header"><div><p class="section-kicker">Última recepción</p><h2>Recepción ${esc(reception.reception_id)}</h2></div><span class="badge neutral">${esc(reception.movement_type)}</span></div><dl class="detail-grid"><div><dt>Fecha</dt><dd>${esc(reception.movement_date)}</dd></div><div><dt>Piezas</dt><dd>${fmt(reception.quantity)}</dd></div><div><dt>Costo</dt><dd>${money(reception.cost)}</dd></div><div><dt>Stock al recibir</dt><dd>${fmt(reception.variant_stock)}</dd></div><div><dt>Documento</dt><dd>${esc(reception.document_number)}</dd></div><div><dt>Despacho interno</dt><dd>${esc(reception.internal_dispatch_id)}</dd></div><div class="wide"><dt>Nota</dt><dd>${esc(reception.note)}</dd></div></dl></section>`;
        result.innerHTML = `${warning}<section class="section-card"><div class="section-header"><div><p class="section-kicker">Resultado live · ${esc(modeTitle)}</p><h2>${esc(stock.sku || data.query)}</h2></div><span class="badge success">${esc(data.function_version)}</span></div><div class="result-layout"><div class="hero-metrics"><article class="sellthrough-panel"><div class="gauge ${hasPriorStock ? 'count-gauge' : ''}" style="--value:${hasPriorStock ? 0 : Math.max(0, Math.min(100, num(summary.sell_through_pct)))};"><div class="gauge-inner"><strong>${hasPriorStock ? fmt(summary.piezas_netas_venta_desde_ultima_recepcion) : pct(summary.sell_through_pct)}</strong><span>${hasPriorStock ? 'vendidas' : 'venta'}</span></div></div><div><p class="metric-label">${hasPriorStock ? (isPeriod ? 'Ventas del periodo' : 'Ventas desde la última recepción') : 'Sell-through por venta'}</p><p class="metric-help">${hasPriorStock ? `${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)} piezas netas vendidas. El rango incluye inventario previo, por lo que no se muestra un sell-through atribuible solo a ${isPeriod ? 'sus entradas' : 'esa recepción'}.` : `${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)} piezas netas vendidas de ${fmt(summary.piezas_recibidas_ultima_recepcion)} recibidas.`}</p></div>
</article>

<article class="reception-age-panel ${
  receptionAgeDanger ? 'danger' : ''
}" >
  <div>
    <p class="metric-label">
      Días desde última recepción
    </p>

    <strong class="reception-age-value">
      ${
        daysSinceLastReception === null
          ? '—'
          : fmt(daysSinceLastReception)
      }
    </strong>

    <p class="metric-help">
      ${
        daysSinceLastReception === null
          ? 'Fecha de recepción no disponible.'
          : receptionAgeDanger
            ? `Última recepción: ${esc(
                reception.movement_date,
              )} · Más de 35 días`
            : `Última recepción: ${esc(
                reception.movement_date,
              )}`
      }
    </p>
  </div>
</article>
</div>

<div class="summary-grid compact"><article class="card"><span>Recibidas</span><strong>${fmt(summary.piezas_recibidas_ultima_recepcion)}</strong><small>${receivedNote}</small></article><article class="card"><span>Vendidas netas</span><strong>${fmt(summary.piezas_netas_venta_desde_ultima_recepcion)}</strong><small>Vendidas: ${fmt(summary.piezas_vendidas_desde_ultima_recepcion)} · Devueltas: ${fmt(summary.piezas_devueltas_desde_ultima_recepcion)}</small></article><article class="card"><span>Consumo / ajuste</span><strong>${fmt(summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion)}</strong><small>Salidas no venta que afectaron stock</small></article><article class="card"><span>Salidas stock</span><strong>${fmt(summary.piezas_salidas_stock_desde_ultima_recepcion)}</strong><small>${hasPriorStock ? `Al menos ${fmt(priorStockMinimum)} de inventario previo` : `${pct(summary.salidas_vs_recepcion_pct)} de entradas`}</small></article><article class="card"><span>Stock actual Bsale live</span><strong>${fmt(summary.stock_actual)}</strong><small>Disponible: ${fmt(summary.stock_disponible)}</small></article><article class="card"><span>Sucursal</span><strong>${esc(stock.office_name)}</strong><small>Variant ID ${esc(data.variant_ids?.join(', '))}</small></article></div></div><p class="muted block-note">Movimientos calculados hasta ${esc(data.end_date)}. El stock actual es live de Bsale.</p></section>${context}<section class="section-card"><div class="section-header"><div><p class="section-kicker">Movimientos por día</p><h2>Recepciones, ventas, devoluciones y ajustes</h2></div><span class="badge neutral">${fmt(timeline.length)} días</span></div><div class="timeline">${timelineHtml || '<p class="muted">Sin movimientos.</p>'}</div></section><section class="section-card muted-card"><div class="section-header"><div><p class="section-kicker">Cobertura revisada</p><h2>Qué leyó la función en Bsale</h2></div><span class="badge neutral">Diagnóstico</span></div><div class="coverage-grid"><article class="coverage-item"><span>Rango</span><strong>${esc(data.scan_start_date || data.start_date)} a ${esc(data.end_date)}</strong><p>Modo: ${esc(modeTitle)}</p></article><article class="coverage-item"><span>Recepciones revisadas</span><strong>${fmt(stats.receptions?.receptions_seen)}</strong><p>Coincidencias: ${fmt(stats.receptions?.matches)}</p></article><article class="coverage-item"><span>Documentos revisados</span><strong>${fmt(stats.documents?.documents_seen)}</strong><p>Líneas: ${fmt(stats.documents?.details_seen)} · matches: ${fmt(stats.documents?.matches)}</p></article><article class="coverage-item"><span>Consumos revisados</span><strong>${fmt(stats.consumptions?.consumptions_seen_in_date_range)}</strong><p>Líneas: ${fmt(stats.consumptions?.details_seen)} · matches: ${fmt(stats.consumptions?.matches)}</p></article><article class="coverage-item"><span>Política</span><strong>Hasta ayer</strong><p>${esc(data.data_policy)}</p></article><article class="coverage-item"><span>Errores API</span><strong>${fmt((stats.receptions?.detail_errors || []).length + (stats.documents?.detail_errors || []).length + (stats.consumptions?.detail_errors || []).length)}</strong><p>Errores acumulados.</p></article></div></section><section class="section-card"><div class="section-header"><div><p class="section-kicker">Detalle</p><h2>Movimientos detectados</h2></div><span class="badge neutral">${fmt(movements.length)} movimientos</span></div><div class="movement-list">${movementsHtml || '<p class="muted">Sin movimientos.</p>'}</div></section>`;
      };

      const downloadPdf = async () => {
        if (!lastCalculation) return;

        pdfButton.disabled = true;
        const originalText = pdfButton.textContent;
        pdfButton.textContent = 'Generando PDF...';

        try {
          const data = lastCalculation;
          const stock = data.stock_matches?.[0] || {};
          const summary = data.summary || {};
          const reception = data.last_reception || {};
          const isPeriod = data.analysis_mode === 'period';
          const modeTitle = isPeriod
            ? 'Periodo explícito'
            : 'Última recepción';

          const daysSinceLastReception = daysSinceDate(
            reception.movement_date,
          );

          const hasPriorStock = Boolean(
            summary.advertencia_salidas_superan_ultima_recepcion,
          );
          const priorStockMinimum = Math.max(
            0,
            num(summary.piezas_salidas_stock_desde_ultima_recepcion) -
              num(summary.piezas_recibidas_ultima_recepcion),
          );
          const receptionAgeDanger =
            !hasPriorStock &&
            daysSinceLastReception !== null &&
            daysSinceLastReception >= 35 &&
            num(summary.sell_through_pct) < 35;

          const sellThrough = Math.max(
            0,
            Math.min(100, num(summary.sell_through_pct)),
          );

          const received = num(
            summary.piezas_recibidas_ultima_recepcion,
          );

          const soldNet = num(
            summary
              .piezas_netas_venta_desde_ultima_recepcion,
          );

          const returned = num(
            summary
              .piezas_devueltas_desde_ultima_recepcion,
          );

          const adjustments = num(
            summary
              .piezas_consumidas_ajuste_stock_desde_ultima_recepcion,
          );

          const stockCurrent = num(summary.stock_actual);
          const stockAvailable = num(summary.stock_disponible);

          const pdf = new jsPDF({
            orientation: 'landscape',
            unit: 'pt',
            format: 'a4',
          });

          const pageWidth =
            pdf.internal.pageSize.getWidth();

          const pageHeight =
            pdf.internal.pageSize.getHeight();

          const margin = 34;
          const contentWidth =
            pageWidth - margin * 2;

          const dark = '#172033';
          const muted = '#64748b';
          const border = '#dbe3ef';
          const soft = '#f8fafc';
          const blue = '#3b82f6';
          const blueSoft = '#dbeafe';
          const red = '#b91c1c';
          const redBorder = '#ef4444';
          const redSoft = '#fff1f2';
          const green = '#166534';
          const greenSoft = '#f0fdf4';

          let y = margin;

          const drawRoundedCard = (
            x,
            yPos,
            width,
            height,
            fillColor = '#ffffff',
            borderColor = border,
          ) => {
            pdf.setLineWidth(0.8);
            pdf.setDrawColor(borderColor);
            pdf.setFillColor(fillColor);
            pdf.roundedRect(
              x,
              yPos,
              width,
              height,
              10,
              10,
              'FD',
            );
          };

          const drawMetricCard = (
            x,
            yPos,
            width,
            label,
            value,
            note,
          ) => {
            drawRoundedCard(
              x,
              yPos,
              width,
              64,
              soft,
              border,
            );

            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(7.5);
            pdf.setTextColor(muted);
            pdf.text(
              plain(label).toUpperCase(),
              x + 13,
              yPos + 17,
            );

            pdf.setFontSize(20);
            pdf.setTextColor(dark);
            pdf.text(
              plain(value),
              x + 13,
              yPos + 42,
              { maxWidth: width - 26 },
            );

            if (note) {
              pdf.setFont(
                'helvetica',
                'normal',
              );
              pdf.setFontSize(7.3);
              pdf.setTextColor(muted);
              pdf.text(
                plain(note),
                x + 13,
                yPos + 56,
                { maxWidth: width - 26 },
              );
            }
          };

          const footerText =
            `Generado ${new Date().toLocaleString('es-MX')} · ` +
            `Datos hasta ${plain(data.end_date)} · ` +
            `${modeTitle}`;

          pdf.setFont('helvetica', 'normal');
          pdf.setFontSize(7);
          pdf.setTextColor(muted);
          pdf.text(
            footerText,
            margin,
            pageHeight - 16,
          );

          pdf.text(
            `SKU ${plain(stock.sku || data.query)}`,
            pageWidth - margin,
            pageHeight - 16,
            { align: 'right' },
          );

          pdf.setFillColor(dark);
          pdf.roundedRect(
            margin,
            y,
            contentWidth,
            68,
            12,
            12,
            'F',
          );

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(8);
          pdf.setTextColor('#94a3b8');
          pdf.text(
            'CHINO REGALADO · BSALE LIVE',
            margin + 18,
            y + 19,
          );

          pdf.setFontSize(22);
          pdf.setTextColor('#ffffff');
          pdf.text(
            'Sell-through por SKU',
            margin + 18,
            y + 45,
          );

          pdf.setFont(
            'helvetica',
            'normal',
          );
          pdf.setFontSize(8.5);
          pdf.setTextColor('#cbd5e1');

          const headerMeta =
            `${plain(stock.sku || data.query)} · ` +
            `${plain(stock.office_name)} · ` +
            `Corte ${plain(data.end_date)}`;

          pdf.text(
            headerMeta,
            pageWidth - margin - 18,
            y + 43,
            {
              align: 'right',
              maxWidth: 360,
            },
          );

          y += 84;

          const heroGap = 12;
          const heroHeight = 108;
          const heroLeftWidth =
            contentWidth * 0.67;

          const heroRightWidth =
            contentWidth -
            heroLeftWidth -
            heroGap;

          drawRoundedCard(
            margin,
            y,
            heroLeftWidth,
            heroHeight,
            dark,
            dark,
          );

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(8);
          pdf.setTextColor('#93c5fd');
          pdf.text(
            hasPriorStock
              ? (isPeriod
                ? 'VENTAS DEL PERIODO'
                : 'VENTAS DESDE LA ÚLTIMA RECEPCIÓN')
              : 'SELL-THROUGH POR VENTA',
            margin + 20,
            y + 24,
          );

          pdf.setFontSize(34);
          pdf.setTextColor('#ffffff');
          pdf.text(
            hasPriorStock ? fmt(soldNet) : pct(sellThrough),
            margin + 20,
            y + 62,
          );

          pdf.setFont(
            'helvetica',
            'normal',
          );
          pdf.setFontSize(10);
          pdf.setTextColor('#cbd5e1');

          pdf.text(
            hasPriorStock
              ? `${fmt(soldNet)} piezas netas vendidas. El rango incluye ` +
                `inventario previo; no se atribuyen solo a sus entradas.`
              : `${fmt(soldNet)} piezas netas vendidas de ` +
                `${fmt(received)} recibidas`,
            margin + 118,
            y + 58,
            {
              maxWidth:
                heroLeftWidth - 140,
            },
          );

          const progressX = margin + 20;
          const progressY = y + 83;
          const progressWidth =
            heroLeftWidth - 40;
          const progressHeight = 9;

          pdf.setFillColor('#334155');
          pdf.roundedRect(
            progressX,
            progressY,
            progressWidth,
            progressHeight,
            4.5,
            4.5,
            'F',
          );

          const progressFill = hasPriorStock
            ? 0
            : progressWidth * (sellThrough / 100);

          if (progressFill > 0) {
            pdf.setFillColor(blue);
            pdf.roundedRect(
              progressX,
              progressY,
              progressFill,
              progressHeight,
              4.5,
              4.5,
              'F',
            );
          }

          const ageX =
            margin +
            heroLeftWidth +
            heroGap;

          drawRoundedCard(
            ageX,
            y,
            heroRightWidth,
            heroHeight,
            receptionAgeDanger
              ? redSoft
              : '#ffffff',
            receptionAgeDanger
              ? redBorder
              : border,
          );

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(7.5);
          pdf.setTextColor(
            receptionAgeDanger
              ? red
              : muted,
          );

          pdf.text(
            'DÍAS DESDE ÚLTIMA RECEPCIÓN',
            ageX + heroRightWidth / 2,
            y + 24,
            { align: 'center' },
          );

          pdf.setFontSize(32);
          pdf.setTextColor(
            receptionAgeDanger
              ? red
              : dark,
          );

          pdf.text(
            daysSinceLastReception === null
              ? '—'
              : fmt(daysSinceLastReception),
            ageX + heroRightWidth / 2,
            y + 65,
            { align: 'center' },
          );

          pdf.setFont(
            'helvetica',
            'normal',
          );
          pdf.setFontSize(8);
          pdf.setTextColor(
            receptionAgeDanger
              ? red
              : muted,
          );

          const ageText =
            daysSinceLastReception === null
              ? 'Fecha no disponible'
              : `Última recepción: ${plain(
                  reception.movement_date,
                )}`;

          pdf.text(
            ageText,
            ageX + heroRightWidth / 2,
            y + 88,
            {
              align: 'center',
              maxWidth:
                heroRightWidth - 24,
            },
          );

          y += heroHeight + 14;

          const metricGap = 10;
          const metricWidth =
            (contentWidth -
              metricGap * 3) /
            4;

          drawMetricCard(
            margin,
            y,
            metricWidth,
            'Recibidas',
            fmt(received),
            isPeriod
              ? `${fmt(
                  data.period_receptions
                    ?.length || 0,
                )} recepciones`
              : `Recepción ${plain(
                  reception.reception_id,
                )}`,
          );

          drawMetricCard(
            margin +
              metricWidth +
              metricGap,
            y,
            metricWidth,
            'Vendidas netas',
            fmt(soldNet),
            `Devueltas: ${fmt(returned)}`,
          );

          drawMetricCard(
            margin +
              (metricWidth + metricGap) * 2,
            y,
            metricWidth,
            'Stock actual',
            fmt(stockCurrent),
            `Disponible: ${fmt(
              stockAvailable,
            )}`,
          );

          drawMetricCard(
            margin +
              (metricWidth + metricGap) * 3,
            y,
            metricWidth,
            'Ajustes no venta',
            fmt(adjustments),
            'Salidas que afectaron stock',
          );

          y += 80;

          let conclusionTitle =
            'ROTACIÓN EN PROGRESO';

          let conclusionText =
            `Se ha vendido el ${pct(
              sellThrough,
            )} de la mercancía recibida.`;

          let conclusionFill = blueSoft;
          let conclusionBorder = blue;
          let conclusionColor = dark;

          if (hasPriorStock) {
            conclusionTitle =
              'INVENTARIO PREVIO DETECTADO';

            conclusionText =
              `${fmt(soldNet)} piezas netas se vendieron ${isPeriod ? 'en el periodo' : 'desde la última recepción'}. ` +
              `Al menos ${fmt(priorStockMinimum)} piezas de las salidas requirieron inventario previo; ` +
              `por eso no se presenta un sell-through atribuible solo a ${isPeriod ? 'las entradas del periodo' : 'esa recepción'}.`;

            conclusionFill = '#fffbeb';
            conclusionBorder = '#f59e0b';
            conclusionColor = '#92400e';
          } else if (receptionAgeDanger) {
            conclusionTitle =
              'ALERTA DE BAJA ROTACIÓN';

            conclusionText =
              `Han pasado ${fmt(
                daysSinceLastReception,
              )} días desde la última recepción y ` +
              `el sell-through por venta es de ${pct(
                sellThrough,
              )}.`;

            conclusionFill = redSoft;
            conclusionBorder = redBorder;
            conclusionColor = red;
          } else if (sellThrough >= 80) {
            conclusionTitle =
              'ROTACIÓN SALUDABLE';

            conclusionText =
              `Se ha vendido el ${pct(
                sellThrough,
              )} de la recepción en ${fmt(
                daysSinceLastReception,
              )} días.`;

            conclusionFill = greenSoft;
            conclusionBorder = '#22c55e';
            conclusionColor = green;
          }

          drawRoundedCard(
            margin,
            y,
            contentWidth,
            62,
            conclusionFill,
            conclusionBorder,
          );

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(8);
          pdf.setTextColor(conclusionColor);
          pdf.text(
            conclusionTitle,
            margin + 15,
            y + 20,
          );

          pdf.setFont(
            'helvetica',
            'normal',
          );
          pdf.setFontSize(9.5);
          pdf.setTextColor(dark);

          pdf.text(
            pdf.splitTextToSize(
              conclusionText,
              contentWidth - 30,
            ),
            margin + 15,
            y + 42,
          );

          y += 78;

          drawRoundedCard(
            margin,
            y,
            contentWidth,
            82,
            '#ffffff',
            border,
          );

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(8);
          pdf.setTextColor(muted);

          pdf.text(
            isPeriod
              ? 'RESUMEN DEL PERIODO'
              : 'DATOS DE LA ÚLTIMA RECEPCIÓN',
            margin + 15,
            y + 19,
          );

          pdf.setFontSize(13);
          pdf.setTextColor(dark);

          const receptionTitle = isPeriod
            ? `${plain(data.start_date)} a ${plain(
                data.end_date,
              )}`
            : `Recepción ${plain(
                reception.reception_id,
              )} · ${plain(
                reception.movement_date,
              )}`;

          pdf.text(
            receptionTitle,
            margin + 15,
            y + 41,
          );

          pdf.setFont(
            'helvetica',
            'normal',
          );
          pdf.setFontSize(8.3);
          pdf.setTextColor(muted);

          const receptionDetails = isPeriod
            ? `Entradas: ${fmt(received)} · ` +
              `Ventas netas: ${fmt(soldNet)} · ` +
              `Devueltas: ${fmt(returned)} · ` +
              `Ajustes: ${fmt(adjustments)}`
            : `Piezas: ${fmt(
                reception.quantity,
              )} · ` +
              `Costo unitario: ${money(
                reception.cost,
              )} · ` +
              `Stock al recibir: ${fmt(
                reception.variant_stock,
              )} · ` +
              `Documento: ${plain(
                reception.document_number,
              )} · ` +
              `Despacho: ${plain(
                reception.internal_dispatch_id,
              )}`;

          pdf.text(
            receptionDetails,
            margin + 15,
            y + 62,
            {
              maxWidth:
                contentWidth - 30,
            },
          );

          pdf.save(
            `sell-through-${fileSafe(
              input.value.trim() ||
                data.query,
            )}-${ymd()}.pdf`,
          );
        } finally {
          pdfButton.disabled = false;
          pdfButton.textContent =
            originalText;
        }
      };

      const sleep = (milliseconds) =>
        new Promise((resolve) => setTimeout(resolve, milliseconds));

      const normalizePeriodResult = (data) => {
        const summary = data?.summary || {};

        return {
          ...data,
          summary: {
            ...summary,
            piezas_recibidas_ultima_recepcion:
              summary.piezas_recibidas_periodo ??
              summary.piezas_recibidas_ultima_recepcion,
            piezas_vendidas_desde_ultima_recepcion:
              summary.piezas_vendidas_periodo ??
              summary.piezas_vendidas_desde_ultima_recepcion,
            piezas_devueltas_desde_ultima_recepcion:
              summary.piezas_devueltas_periodo ??
              summary.piezas_devueltas_desde_ultima_recepcion,
            piezas_netas_venta_desde_ultima_recepcion:
              summary.piezas_netas_venta_periodo ??
              summary.piezas_netas_venta_desde_ultima_recepcion,
            piezas_consumidas_ajuste_desde_ultima_recepcion:
              summary.piezas_consumidas_ajuste_periodo ??
              summary.piezas_consumidas_ajuste_desde_ultima_recepcion,
            piezas_consumidas_ajuste_stock_desde_ultima_recepcion:
              summary.piezas_consumidas_ajuste_stock_periodo ??
              summary.piezas_consumidas_ajuste_stock_desde_ultima_recepcion,
            piezas_salidas_stock_desde_ultima_recepcion:
              summary.piezas_salidas_stock_periodo ??
              summary.piezas_salidas_stock_desde_ultima_recepcion,
            salidas_vs_recepcion_pct:
              summary.salidas_vs_recepciones_periodo_pct ??
              summary.salidas_vs_recepcion_pct,
            advertencia_salidas_superan_ultima_recepcion:
              summary.advertencia_salidas_superan_recepciones_periodo ??
              summary.advertencia_salidas_superan_ultima_recepcion,
          },
        };
      };

      const invokePeriodRequest = async (action, request) => {
        const { data, error } = await supabase.functions.invoke(
          'request-sell-through-period-v1',
          {
            body: {
              action,
              query: request.query,
              office_id: request.officeId,
              period_start_date: request.startDate,
              period_end_date: request.endDate,
            },
          },
        );

        if (error) throw error;
        if (data?.ok === false || data?.error) {
          throw new Error(data?.error || 'No se pudo solicitar el cálculo.');
        }

        return data;
      };

      const getPeriodResult = async (request) => {
        const initial = await invokePeriodRequest('start', request);

        if (initial?.status === 'ready' && initial?.result) {
          return normalizePeriodResult(initial.result);
        }

        if (initial?.status !== 'processing') {
          throw new Error('La solicitud devolvió un estado inesperado.');
        }

        for (let attempt = 1; attempt <= 40; attempt += 1) {
          setStatus(
            `Procesando periodo en segundo plano... ${attempt * 15}s`,
          );

          await sleep(15_000);

          const check = await invokePeriodRequest('check', request);

          if (check?.status === 'ready' && check?.result) {
            return normalizePeriodResult(check.result);
          }
        }

        throw new Error(
          'El cálculo continúa en proceso. Intenta consultar nuevamente en unos minutos.',
        );
      };

      pdfButton.addEventListener('click', downloadPdf);

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const query = input.value.trim();
        const mode = modeSelect.value;

        if (!query) {
          return setStatus('Escribe un SKU o código de barras.');
        }

        if (
          mode === 'period' &&
          (!periodStart.value || !periodEnd.value)
        ) {
          return setStatus(
            'Selecciona fecha inicial y fecha final.',
          );
        }

        if (
          mode === 'period' &&
          periodStart.value > periodEnd.value
        ) {
          return setStatus(
            'La fecha inicial no puede ser mayor que la fecha final.',
          );
        }

        button.disabled = true;
        showPdf(false);
        result.innerHTML = '';

        try {
          let data;

          if (mode === 'period') {
            setStatus('Consultando resultado del periodo...');

            data = await getPeriodResult({
              query,
              officeId: Number(officeSelect.value),
              startDate: periodStart.value,
              endDate: periodEnd.value,
            });
          } else {
            setStatus('Buscando última recepción...');

            const body = {
              query,
              office_ids: [Number(officeSelect.value)],
              analysis_mode: mode,
              lookback_days: 365,
              max_reception_pages_per_office: 0,
              max_document_pages_per_day_type: 0,
              max_consumption_pages_per_office: 0,
              max_reception_details: 1000,
              max_document_details: 1000,
              max_consumption_details: 1000,
            };

            const response = await supabase.functions.invoke(
              'calculate-sell-through-live-v2',
              { body },
            );

            if (response.error) throw response.error;
            if (response.data?.error) {
              throw new Error(response.data.error);
            }

            data = response.data;
          }

          setStatus('');
          renderData(data);
        } catch (error) {
          setStatus('');
          renderError(error);
        } finally {
          button.disabled = false;
        }
      });
    </script>
  </body>
</html>

