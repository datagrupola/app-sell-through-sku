---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sell-through live por SKU</title>
  </head>

  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Chino Regalado · Bsale live</p>
        <h1>Sell-through live por SKU</h1>
        <p class="subtitle">
          Calcula stock actual, última recepción, ventas desde la última recepción y sell-through directamente desde Bsale.
        </p>
      </section>

      <section class="panel">
        <form id="search-form" class="search-form">
          <label>
            SKU o código de barras
            <input id="search-input" type="text" placeholder="Ej. LJNJ-00034" autocomplete="off" required />
          </label>

          <label>
            Sucursal
            <select id="office-select">
              <option value="2">CHINO LAS AMERICAS</option>
              <option value="3">CHINO LA HUERTA</option>
              <option value="4">CHINO LEON CENTRO</option>
            </select>
          </label>

          <label>
            Buscar recepción en
            <select id="lookback-select">
              <option value="10">Últimos 10 días</option>
              <option value="30" selected>Últimos 30 días</option>
              <option value="90">Últimos 90 días</option>
              <option value="180">Últimos 180 días</option>
              <option value="365">Últimos 365 días</option>
            </select>
          </label>

          <button id="search-button" type="submit">Calcular</button>
        </form>

        <div id="status" class="status"></div>
        <div id="result" class="result"></div>
      </section>
    </main>

    <script>
      import { supabase } from '../lib/supabase.js';

      const form = document.querySelector('#search-form');
      const input = document.querySelector('#search-input');
      const officeSelect = document.querySelector('#office-select');
      const lookbackSelect = document.querySelector('#lookback-select');
      const button = document.querySelector('#search-button');
      const status = document.querySelector('#status');
      const result = document.querySelector('#result');

      const money = (value) => {
        return Number(value || 0).toLocaleString('es-MX', {
          style: 'currency',
          currency: 'MXN',
        });
      };

      const number = (value) => {
        return Number(value || 0).toLocaleString('es-MX', {
          maximumFractionDigits: 2,
        });
      };

      const pct = (value) => {
        if (value === null || value === undefined || value === '') return '—';
        return `${number(value)}%`;
      };

      const text = (value) => {
        if (value === null || value === undefined || value === '') return '—';
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      };

      const setStatus = (message) => {
        status.textContent = message;
      };

      const movementClass = (group) => {
        if (group === 'ENTRADA') return 'movement-entry';
        if (group === 'VENTA') return 'movement-sale';
        if (group === 'DEVOLUCION') return 'movement-return';
        return '';
      };

      const renderNotFound = (data) => {
        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Resultado</p>
                <h2>SKU no encontrado</h2>
              </div>
              <span class="badge neutral">Sin coincidencia</span>
            </div>

            <p class="muted">
              No se encontró variant_id para <strong>${text(data?.query || input.value)}</strong>
              en el índice técnico de Supabase.
            </p>

            <p class="muted small-note">
              Esto puede pasar si el SKU es nuevo, si la recepción aún no está finalizada en Bsale,
              o si el índice de stock actual no se ha sincronizado.
            </p>
          </section>
        `;
      };

      const renderNoReception = (data) => {
        const stock = data.stock_matches?.[0];
        const summary = data.summary || {};

        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Bsale live</p>
                <h2>SKU encontrado, sin recepción en rango</h2>
              </div>
              <span class="badge warning">Sin última recepción</span>
            </div>

            <div class="summary-grid">
              <article class="card primary">
                <span>SKU</span>
                <strong>${text(stock?.sku || data.query)}</strong>
                <small>${text(stock?.office_name)}</small>
              </article>

              <article class="card">
                <span>Stock actual</span>
                <strong>${number(summary.stock_actual)}</strong>
                <small>Disponible: ${number(summary.stock_disponible)}</small>
              </article>

              <article class="card">
                <span>Variant ID</span>
                <strong>${text(data.variant_ids?.join(', '))}</strong>
                <small>Rango: ${text(data.start_date)} a ${text(data.end_date)}</small>
              </article>
            </div>

            <p class="muted block-note">
              El SKU existe, pero no se encontró recepción dentro del rango consultado.
              Amplía el rango de búsqueda y vuelve a calcular.
            </p>
          </section>
        `;
      };

      const renderData = (data) => {
        if (!data?.found) {
          renderNotFound(data);
          return;
        }

        if (!data?.sell_through_found) {
          renderNoReception(data);
          return;
        }

        const stock = data.stock_matches?.[0];
        const summary = data.summary || {};
        const reception = data.last_reception || {};
        const movements = data.movements || [];
        const scanStats = data.scan_stats || {};

        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Resultado live</p>
                <h2>${text(stock?.sku || data.query)}</h2>
              </div>
              <span class="badge success">Calculado desde Bsale</span>
            </div>

            <div class="summary-grid">
              <article class="card primary">
                <span>Sell-through</span>
                <strong>${pct(summary.sell_through_pct)}</strong>
                <small>Desde última recepción</small>
              </article>

              <article class="card">
                <span>Piezas recibidas</span>
                <strong>${number(summary.piezas_recibidas_ultima_recepcion)}</strong>
                <small>Recepción ${text(reception.reception_id)}</small>
              </article>

              <article class="card">
                <span>Piezas vendidas</span>
                <strong>${number(summary.piezas_vendidas_desde_ultima_recepcion)}</strong>
                <small>Devueltas: ${number(summary.piezas_devueltas_desde_ultima_recepcion)}</small>
              </article>

              <article class="card">
                <span>Stock actual</span>
                <strong>${number(summary.stock_actual)}</strong>
                <small>Disponible: ${number(summary.stock_disponible)}</small>
              </article>

              <article class="card">
                <span>Venta neta piezas</span>
                <strong>${number(summary.piezas_netas_venta_desde_ultima_recepcion)}</strong>
                <small>Desde ${text(reception.movement_date)}</small>
              </article>

              <article class="card">
                <span>Costo recepción</span>
                <strong>${money(reception.cost)}</strong>
                <small>Variant ID: ${text(stock?.variant_id)}</small>
              </article>
            </div>
          </section>

          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Última recepción</p>
                <h2>Origen del cálculo</h2>
              </div>
              <span class="badge neutral">${text(reception.movement_date)}</span>
            </div>

            <dl>
              <div>
                <dt>Recepción</dt>
                <dd>${text(reception.reception_id)}</dd>
              </div>
              <div>
                <dt>Tipo entrada</dt>
                <dd>${text(reception.movement_type)}</dd>
              </div>
              <div>
                <dt>Piezas recibidas</dt>
                <dd>${number(reception.quantity)}</dd>
              </div>
              <div>
                <dt>Costo</dt>
                <dd>${money(reception.cost)}</dd>
              </div>
              <div>
                <dt>Stock al recibir</dt>
                <dd>${number(reception.variant_stock)}</dd>
              </div>
              <div>
                <dt>Nota</dt>
                <dd>${text(reception.note)}</dd>
              </div>
            </dl>
          </section>

          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Movimientos</p>
                <h2>Línea de tiempo desde última recepción</h2>
              </div>
              <span class="badge neutral">${number(movements.length)} movimientos</span>
            </div>

            ${
              movements.length
                ? `<div class="timeline">
                    ${movements
                      .map(
                        (item) => `
                          <article class="movement ${movementClass(item.movement_group)}">
                            <div class="movement-header">
                              <div>
                                <strong>${text(item.movement_group)}</strong>
                                <span>${text(item.movement_type)}</span>
                              </div>
                              <div class="movement-numbers">
                                <span>${text(item.movement_date)}</span>
                                <strong>${number(item.quantity_signed ?? item.quantity)}</strong>
                              </div>
                            </div>
                            <p>${text(item.note)}</p>
                            <small>
                              ${item.document_id ? `Documento ID: ${text(item.document_id)}` : ''}
                              ${item.reception_id ? `Recepción ID: ${text(item.reception_id)}` : ''}
                            </small>
                          </article>
                        `
                      )
                      .join('')}
                  </div>`
                : '<p class="muted">Sin movimientos encontrados.</p>'
            }
          </section>

          <section class="section-card muted-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Diagnóstico técnico</p>
                <h2>Cobertura revisada</h2>
              </div>
              <span class="badge neutral">Live</span>
            </div>

            <dl>
              <div>
                <dt>Rango consultado</dt>
                <dd>${text(data.start_date)} a ${text(data.end_date)}</dd>
              </div>
              <div>
                <dt>Páginas recepciones</dt>
                <dd>${number(scanStats.receptions?.pages)}</dd>
              </div>
              <div>
                <dt>Matches recepciones</dt>
                <dd>${number(scanStats.receptions?.matches)}</dd>
              </div>
              <div>
                <dt>Páginas documentos</dt>
                <dd>${number(scanStats.documents?.pages)}</dd>
              </div>
              <div>
                <dt>Matches documentos</dt>
                <dd>${number(scanStats.documents?.matches)}</dd>
              </div>
              <div>
                <dt>Detalles documentos</dt>
                <dd>${number(scanStats.documents?.details_seen)}</dd>
              </div>
            </dl>
          </section>
        `;
      };

      const renderError = (error) => {
        result.innerHTML = `
          <section class="section-card error-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Error</p>
                <h2>No se pudo calcular</h2>
              </div>
              <span class="badge danger">Error</span>
            </div>

            <p class="muted">${text(error?.message || error)}</p>
          </section>
        `;
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const searchValue = input.value.trim();
        const officeId = Number(officeSelect.value);
        const lookbackDays = Number(lookbackSelect.value);

        if (!searchValue) {
          setStatus('Escribe un SKU o código de barras.');
          result.innerHTML = '';
          return;
        }

        button.disabled = true;
        result.innerHTML = '';
        setStatus('Calculando sell-through live desde Bsale...');

        const { data, error } = await supabase.functions.invoke('calculate-sell-through-live', {
          body: {
            query: searchValue,
            office_ids: [officeId],
            lookback_days: lookbackDays,
            max_reception_pages_per_office: 0,
            max_document_pages_per_day_type: 0,
            max_reception_details: 1000,
          },
        });

        button.disabled = false;
        setStatus('');

        if (error) {
          renderError(error);
          return;
        }

        if (data?.error) {
          renderError(data.error);
          return;
        }

        renderData(data);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    color: #172033;
    background: #f4f6fb;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
  }

  .page {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 48px 0;
  }

  .hero {
    margin-bottom: 28px;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 8px;
    color: #64748b;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(32px, 6vw, 56px);
    line-height: 1;
  }

  h2 {
    margin: 0;
    font-size: 24px;
  }

  .subtitle {
    max-width: 760px;
    margin: 16px 0 0;
    color: #64748b;
    font-size: 18px;
  }

  .panel,
  .section-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
  }

  .panel {
    padding: 24px;
  }

  .search-form {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr auto;
    gap: 16px;
    align-items: end;
  }

  label {
    display: grid;
    gap: 8px;
    color: #334155;
    font-size: 14px;
    font-weight: 800;
  }

  input,
  select,
  button {
    width: 100%;
    border-radius: 14px;
    border: 1px solid #cbd5e1;
    padding: 14px 16px;
    font: inherit;
  }

  button {
    border: 0;
    background: #172033;
    color: white;
    font-weight: 900;
    cursor: pointer;
  }

  button:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .status {
    margin-top: 18px;
    color: #64748b;
    font-weight: 800;
  }

  .result {
    display: grid;
    gap: 18px;
    margin-top: 24px;
  }

  .section-card {
    padding: 20px;
  }

  .muted-card {
    background: #f8fafc;
    box-shadow: none;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .badge {
    display: inline-flex;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 12px;
    font-weight: 900;
    white-space: nowrap;
  }

  .badge.success {
    background: #dcfce7;
    color: #166534;
  }

  .badge.warning {
    background: #fef3c7;
    color: #92400e;
  }

  .badge.neutral {
    background: #e2e8f0;
    color: #334155;
  }

  .badge.danger {
    background: #fee2e2;
    color: #991b1b;
  }

  .error-card {
    border-color: #fecaca;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .card {
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    padding: 18px;
    background: #f8fafc;
  }

  .card span {
    display: block;
    color: #64748b;
    font-size: 13px;
    font-weight: 800;
  }

  .card strong {
    display: block;
    margin-top: 8px;
    font-size: 26px;
    overflow-wrap: anywhere;
  }

  .card small {
    display: block;
    margin-top: 6px;
    color: #64748b;
  }

  .primary {
    background: #172033;
    color: white;
  }

  .primary span,
  .primary small {
    color: #dbe4f0;
  }

  dl {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin: 0;
  }

  dt {
    color: #64748b;
    font-size: 13px;
    font-weight: 800;
  }

  dd {
    margin: 4px 0 0;
    font-weight: 900;
    overflow-wrap: anywhere;
  }

  .timeline {
    display: grid;
    gap: 12px;
  }

  .movement {
    display: grid;
    gap: 10px;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 14px;
    background: #ffffff;
  }

  .movement-entry {
    border-color: #bbf7d0;
  }

  .movement-sale {
    border-color: #bfdbfe;
  }

  .movement-return {
    border-color: #fed7aa;
  }

  .movement-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .movement-header span {
    display: block;
    margin-top: 4px;
    color: #64748b;
  }

  .movement-numbers {
    text-align: right;
  }

  .movement p {
    margin: 0;
    color: #64748b;
  }

  .movement small {
    color: #94a3b8;
    font-weight: 800;
  }

  .muted {
    margin: 0;
    color: #64748b;
    line-height: 1.55;
  }

  .small-note {
    margin-top: 8px;
    font-size: 14px;
  }

  .block-note {
    margin-top: 16px;
  }

  @media (max-width: 980px) {
    .search-form {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 760px) {
    .search-form,
    .summary-grid,
    dl {
      grid-template-columns: 1fr;
    }

    .section-header,
    .movement-header {
      display: grid;
    }

    .movement-numbers {
      text-align: left;
    }
  }
</style>
