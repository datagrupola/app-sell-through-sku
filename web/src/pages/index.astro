---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sell-through live por SKU</title>
  </head>

  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Chino Regalado · Bsale live</p>
        <h1>Sell-through live por SKU</h1>
        <p class="subtitle">
          Calcula stock actual, última recepción, ventas desde la última recepción y sell-through directamente desde Bsale.
        </p>
      </section>

      <section class="panel">
        <form id="search-form" class="search-form">
          <label>
            SKU o código de barras
            <input id="search-input" type="text" placeholder="Ej. LJNJ-00034" autocomplete="off" required />
          </label>

          <label>
            Sucursal
            <select id="office-select">
              <option value="2">CHINO LAS AMERICAS</option>
              <option value="3">CHINO LA HUERTA</option>
              <option value="4">CHINO LEON CENTRO</option>
            </select>
          </label>

          <label>
            Buscar recepción en
            <select id="lookback-select">
              <option value="10">Últimos 10 días</option>
              <option value="30" selected>Últimos 30 días</option>
              <option value="90">Últimos 90 días</option>
              <option value="180">Últimos 180 días</option>
              <option value="365">Últimos 365 días</option>
            </select>
          </label>

          <button id="search-button" type="submit">Calcular</button>
        </form>

        <div class="actions-row">
          <div id="status" class="status"></div>
          <button id="pdf-button" class="secondary-button" type="button" hidden>
            Descargar PDF
          </button>
        </div>

        <div id="result" class="result"></div>
      </section>
    </main>

    <script>
      import { supabase } from '../lib/supabase.js';
      import { jsPDF } from 'jspdf';

      const form = document.querySelector('#search-form');
      const input = document.querySelector('#search-input');
      const officeSelect = document.querySelector('#office-select');
      const lookbackSelect = document.querySelector('#lookback-select');
      const button = document.querySelector('#search-button');
      const pdfButton = document.querySelector('#pdf-button');
      const status = document.querySelector('#status');
      const result = document.querySelector('#result');

      let lastCalculation = null;

      const money = (value) => {
        return Number(value || 0).toLocaleString('es-MX', {
          style: 'currency',
          currency: 'MXN',
        });
      };

      const number = (value) => {
        return Number(value || 0).toLocaleString('es-MX', {
          maximumFractionDigits: 2,
        });
      };

      const pct = (value) => {
        if (value === null || value === undefined || value === '') return '—';
        return `${number(value)}%`;
      };

      const clamp = (value, min, max) => {
        return Math.max(min, Math.min(max, Number(value || 0)));
      };

      const text = (value) => {
        if (value === null || value === undefined || value === '') return '—';
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      };

      const setStatus = (message) => {
        status.textContent = message;
      };

      const setPdfAvailable = (available) => {
        pdfButton.hidden = !available;
      };

      const fileSafe = (value) => {
        return String(value || 'sku')
          .trim()
          .replace(/[^a-z0-9-_]+/gi, '-')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '')
          .toLowerCase();
      };

      const downloadPdf = async () => {
        if (!lastCalculation) return;

        pdfButton.disabled = true;
        const originalText = pdfButton.textContent;
        pdfButton.textContent = 'Generando PDF...';

        try {
          const data = lastCalculation;
          const stock = data.stock_matches?.[0] || {};
          const summary = data.summary || {};
          const reception = data.last_reception || {};
          const movements = data.movements || [];
          const scanStats = data.scan_stats || {};

          const pdf = new jsPDF({
            orientation: 'landscape',
            unit: 'pt',
            format: 'a4',
          });

          const pageWidth = pdf.internal.pageSize.getWidth();
          const pageHeight = pdf.internal.pageSize.getHeight();
          const margin = 34;
          const dark = '#172033';
          const muted = '#64748b';
          const border = '#dbe3ef';
          const soft = '#f8fafc';
          const green = '#166534';
          const blue = '#2563eb';

          let y = margin;

          const safe = (value) => {
            if (value === null || value === undefined || value === '') return '—';
            return String(value);
          };

          const fmt = (value) => {
            return Number(value || 0).toLocaleString('es-MX', {
              maximumFractionDigits: 2,
            });
          };

          const fmtMoney = (value) => {
            return Number(value || 0).toLocaleString('es-MX', {
              style: 'currency',
              currency: 'MXN',
            });
          };

          const addPageIfNeeded = (neededHeight) => {
            if (y + neededHeight <= pageHeight - margin) return;
            pdf.addPage();
            y = margin;
          };

          const sectionTitle = (eyebrow, title) => {
            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(8);
            pdf.setTextColor(muted);
            pdf.text(eyebrow.toUpperCase(), margin, y);
            y += 14;

            pdf.setFontSize(15);
            pdf.setTextColor(dark);
            pdf.text(title, margin, y);
            y += 18;
          };

          const card = (x, yPos, w, h, label, value, note = '') => {
            pdf.setDrawColor(border);
            pdf.setFillColor(soft);
            pdf.roundedRect(x, yPos, w, h, 10, 10, 'FD');

            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(8);
            pdf.setTextColor(muted);
            pdf.text(label, x + 12, yPos + 18);

            pdf.setFontSize(22);
            pdf.setTextColor(dark);
            pdf.text(safe(value), x + 12, yPos + 45);

            if (note) {
              pdf.setFontSize(8);
              pdf.setTextColor(muted);
              pdf.text(safe(note), x + 12, yPos + 62, { maxWidth: w - 24 });
            }
          };

          const pill = (label, x, yPos) => {
            pdf.setFillColor('#dcfce7');
            pdf.roundedRect(x, yPos - 11, 86, 18, 9, 9, 'F');
            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(7);
            pdf.setTextColor(green);
            pdf.text(label, x + 9, yPos + 1);
          };

          // Header
          pdf.setFont('helvetica', 'bold');
          pdf.setTextColor(muted);
          pdf.setFontSize(8);
          pdf.text('CHINO REGALADO · BSALE LIVE', margin, y);

          pill('Calculado live', pageWidth - margin - 86, y);
          y += 26;

          pdf.setTextColor(dark);
          pdf.setFontSize(28);
          pdf.text('Reporte sell-through por SKU', margin, y);
          y += 24;

          pdf.setFont('helvetica', 'normal');
          pdf.setFontSize(10);
          pdf.setTextColor(muted);
          pdf.text(
            `SKU: ${safe(stock.sku || data.query)}   ·   Sucursal: ${safe(stock.office_name)}   ·   Consulta: ${new Date().toLocaleString('es-MX')}`,
            margin,
            y
          );
          y += 26;

          // Main result box
          const boxX = margin;
          const boxY = y;
          const boxW = pageWidth - margin * 2;
          const boxH = 118;

          pdf.setDrawColor(border);
          pdf.setFillColor('#ffffff');
          pdf.roundedRect(boxX, boxY, boxW, boxH, 14, 14, 'FD');

          // Dark sell-through panel
          pdf.setFillColor(dark);
          pdf.roundedRect(boxX + 14, boxY + 14, 180, 90, 12, 12, 'F');

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(31);
          pdf.setTextColor('#ffffff');
          pdf.text(`${fmt(summary.sell_through_pct)}%`, boxX + 30, boxY + 55);

          pdf.setFontSize(9);
          pdf.text('Sell-through', boxX + 32, boxY + 74);

          pdf.setFont('helvetica', 'normal');
          pdf.setTextColor('#cbd5e1');
          pdf.text('desde última recepción', boxX + 32, boxY + 88);

          // Progress bar
          const progressX = boxX + 215;
          const progressY = boxY + 24;
          const progressW = boxW - 235;
          const progressH = 12;
          const percent = Math.max(0, Math.min(100, Number(summary.sell_through_pct || 0)));

          pdf.setFillColor('#e2e8f0');
          pdf.roundedRect(progressX, progressY, progressW, progressH, 6, 6, 'F');
          pdf.setFillColor(blue);
          pdf.roundedRect(progressX, progressY, progressW * (percent / 100), progressH, 6, 6, 'F');

          const kpiW = (progressW - 48) / 4;
          const kpiY = boxY + 48;

          card(progressX, kpiY, kpiW, 56, 'Recibidas', fmt(summary.piezas_recibidas_ultima_recepcion), `Recepción ${safe(reception.reception_id)}`);
          card(progressX + kpiW + 16, kpiY, kpiW, 56, 'Vendidas', fmt(summary.piezas_vendidas_desde_ultima_recepcion), `Devueltas: ${fmt(summary.piezas_devueltas_desde_ultima_recepcion)}`);
          card(progressX + (kpiW + 16) * 2, kpiY, kpiW, 56, 'Stock actual', fmt(summary.stock_actual), `Disponible: ${fmt(summary.stock_disponible)}`);
          card(progressX + (kpiW + 16) * 3, kpiY, kpiW, 56, 'Venta neta', fmt(summary.piezas_netas_venta_desde_ultima_recepcion), `Desde ${safe(reception.movement_date)}`);

          y += boxH + 24;

          // Two columns: reception + timeline
          const colGap = 18;
          const leftW = 285;
          const rightW = boxW - leftW - colGap;
          const colY = y;
          const colH = 190;

          pdf.setDrawColor(border);
          pdf.setFillColor('#ffffff');
          pdf.roundedRect(margin, colY, leftW, colH, 14, 14, 'FD');
          pdf.roundedRect(margin + leftW + colGap, colY, rightW, colH, 14, 14, 'FD');

          // Reception
          let rx = margin + 16;
          let ry = colY + 22;

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(8);
          pdf.setTextColor(muted);
          pdf.text('ÚLTIMA RECEPCIÓN', rx, ry);
          ry += 18;

          pdf.setFontSize(16);
          pdf.setTextColor(dark);
          pdf.text('Origen del cálculo', rx, ry);
          ry += 28;

          const receptionRows = [
            ['Fecha', safe(reception.movement_date)],
            ['Recepción', safe(reception.reception_id)],
            ['Piezas', fmt(reception.quantity)],
            ['Costo', fmtMoney(reception.cost)],
            ['Stock al recibir', fmt(reception.variant_stock)],
          ];

          pdf.setFontSize(9);
          for (const [label, value] of receptionRows) {
            pdf.setTextColor(muted);
            pdf.setFont('helvetica', 'bold');
            pdf.text(label, rx, ry);
            pdf.setTextColor(dark);
            pdf.text(value, rx + 92, ry);
            ry += 17;
          }

          pdf.setTextColor(muted);
          pdf.setFont('helvetica', 'bold');
          pdf.text('Nota', rx, ry);
          ry += 14;
          pdf.setTextColor(dark);
          pdf.text(safe(reception.note), rx, ry, { maxWidth: leftW - 32 });

          // Timeline
          let tx = margin + leftW + colGap + 16;
          let ty = colY + 22;

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(8);
          pdf.setTextColor(muted);
          pdf.text('MOVIMIENTOS', tx, ty);
          ty += 18;

          pdf.setFontSize(16);
          pdf.setTextColor(dark);
          pdf.text('Línea de tiempo desde última recepción', tx, ty);
          ty += 22;

          const timelineMax = Math.min(movements.length, 5);
          for (let i = 0; i < timelineMax; i++) {
            const item = movements[i];
            const isEntry = item.movement_group === 'ENTRADA';

            pdf.setFillColor(isEntry ? '#16a34a' : '#2563eb');
            pdf.circle(tx + 5, ty - 4, 4, 'F');

            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(9);
            pdf.setTextColor(dark);
            pdf.text(safe(item.movement_date), tx + 18, ty);

            pdf.text(safe(item.movement_group), tx + 104, ty);

            pdf.setFontSize(14);
            pdf.text(fmt(item.quantity_signed ?? item.quantity), tx + rightW - 50, ty);

            pdf.setFont('helvetica', 'normal');
            pdf.setFontSize(8);
            pdf.setTextColor(muted);
            pdf.text(safe(item.note), tx + 104, ty + 13, { maxWidth: rightW - 170 });

            ty += 32;
          }

          if (movements.length > timelineMax) {
            pdf.setFont('helvetica', 'normal');
            pdf.setFontSize(8);
            pdf.setTextColor(muted);
            pdf.text(`+ ${movements.length - timelineMax} movimientos adicionales`, tx + 18, ty);
          }

          y += colH + 24;

          // Compact coverage footer
          const footerY = pageHeight - margin - 50;

          pdf.setDrawColor(border);
          pdf.setFillColor('#f8fafc');
          pdf.roundedRect(margin, footerY, boxW, 50, 10, 10, 'FD');

          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(8);
          pdf.setTextColor(muted);
          pdf.text('COBERTURA REVISADA', margin + 12, footerY + 16);

          pdf.setFont('helvetica', 'normal');
          pdf.setFontSize(8);
          pdf.setTextColor(dark);

          const coverageLine =
            `Rango: ${safe(data.start_date)} a ${safe(data.end_date)}  ·  ` +
            `Recepciones revisadas: ${fmt(scanStats.receptions?.receptions_seen)}  ·  ` +
            `Recepciones con SKU: ${fmt(scanStats.receptions?.matches)}  ·  ` +
            `Documentos revisados: ${fmt(scanStats.documents?.documents_seen)}  ·  ` +
            `Líneas revisadas: ${fmt(scanStats.documents?.details_seen)}  ·  ` +
            `Ventas/devoluciones del SKU: ${fmt(scanStats.documents?.matches)}`;

          pdf.text(coverageLine, margin + 12, footerY + 33, { maxWidth: boxW - 24 });

          const sku = input.value.trim() || 'sku';
          const date = new Date().toISOString().slice(0, 10);
          pdf.save(`sell-through-${fileSafe(sku)}-${date}.pdf`);
        } finally {
          pdfButton.disabled = false;
          pdfButton.textContent = originalText;
        }
      };

      pdfButton.addEventListener('click', downloadPdf);

      const movementClass = (group) => {
        if (group === 'ENTRADA') return 'timeline-entry';
        if (group === 'VENTA') return 'timeline-sale';
        if (group === 'DEVOLUCION') return 'timeline-return';
        return '';
      };

      const movementLabel = (item) => {
        if (item.movement_group === 'ENTRADA') return 'Entrada';
        if (item.movement_group === 'VENTA') return 'Venta';
        if (item.movement_group === 'DEVOLUCION') return 'Devolución';
        return text(item.movement_group);
      };

      const movementReference = (item) => {
        if (item.document_id) return `Documento ${item.note || item.document_id}`;
        if (item.reception_id) return `Recepción ${item.reception_id}`;
        return item.note || 'Movimiento';
      };

      const sellThroughLevel = (value) => {
        const numeric = Number(value || 0);

        if (numeric >= 80) return 'Alto';
        if (numeric >= 50) return 'Medio';
        if (numeric >= 20) return 'Bajo';
        return 'Inicial';
      };

      const renderNotFound = (data) => {
        setPdfAvailable(true);

        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Resultado</p>
                <h2>SKU no encontrado</h2>
              </div>
              <span class="badge neutral">Sin coincidencia</span>
            </div>

            <p class="muted">
              No se encontró variant_id para <strong>${text(data?.query || input.value)}</strong>
              en el índice técnico de Supabase.
            </p>

            <p class="muted small-note">
              Esto puede pasar si el SKU es nuevo, si la recepción aún no está finalizada en Bsale,
              o si el índice de stock actual no se ha sincronizado.
            </p>
          </section>
        `;
      };

      const renderNoReception = (data) => {
        const stock = data.stock_matches?.[0];
        const summary = data.summary || {};

        setPdfAvailable(true);

        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Bsale live</p>
                <h2>SKU encontrado, sin recepción en rango</h2>
              </div>
              <span class="badge warning">Sin última recepción</span>
            </div>

            <div class="summary-grid">
              <article class="card primary">
                <span>SKU</span>
                <strong>${text(stock?.sku || data.query)}</strong>
                <small>${text(stock?.office_name)}</small>
              </article>

              <article class="card">
                <span>Stock actual</span>
                <strong>${number(summary.stock_actual)}</strong>
                <small>Disponible: ${number(summary.stock_disponible)}</small>
              </article>

              <article class="card">
                <span>Variant ID</span>
                <strong>${text(data.variant_ids?.join(', '))}</strong>
                <small>Rango: ${text(data.start_date)} a ${text(data.end_date)}</small>
              </article>
            </div>

            <p class="muted block-note">
              El SKU existe, pero no se encontró recepción dentro del rango consultado.
              Amplía el rango de búsqueda y vuelve a calcular.
            </p>
          </section>
        `;
      };

      const renderData = (data) => {
        lastCalculation = data;

        if (!data?.found) {
          renderNotFound(data);
          return;
        }

        if (!data?.sell_through_found) {
          renderNoReception(data);
          return;
        }

        const stock = data.stock_matches?.[0];
        const summary = data.summary || {};
        const reception = data.last_reception || {};
        const movements = data.movements || [];
        const scanStats = data.scan_stats || {};

        const sellThroughValue = Number(summary.sell_through_pct || 0);
        const sellThroughClamped = clamp(sellThroughValue, 0, 100);
        const sellThroughStatus = sellThroughLevel(sellThroughValue);

        setPdfAvailable(true);

        result.innerHTML = `
          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Resultado live</p>
                <h2>${text(stock?.sku || data.query)}</h2>
              </div>
              <span class="badge success">Calculado desde Bsale</span>
            </div>

            <div class="result-layout">
              <article class="sellthrough-panel">
                <div class="gauge" style="--value: ${sellThroughClamped};">
                  <div class="gauge-inner">
                    <strong>${pct(summary.sell_through_pct)}</strong>
                    <span>${sellThroughStatus}</span>
                  </div>
                </div>

                <div>
                  <p class="metric-label">Sell-through desde última recepción</p>
                  <p class="metric-help">
                    ${number(summary.piezas_netas_venta_desde_ultima_recepcion)}
                    piezas netas vendidas de
                    ${number(summary.piezas_recibidas_ultima_recepcion)}
                    recibidas.
                  </p>
                </div>
              </article>

              <div class="summary-grid compact">
                <article class="card">
                  <span>Piezas recibidas</span>
                  <strong>${number(summary.piezas_recibidas_ultima_recepcion)}</strong>
                  <small>Recepción ${text(reception.reception_id)}</small>
                </article>

                <article class="card">
                  <span>Piezas vendidas</span>
                  <strong>${number(summary.piezas_vendidas_desde_ultima_recepcion)}</strong>
                  <small>Devueltas: ${number(summary.piezas_devueltas_desde_ultima_recepcion)}</small>
                </article>

                <article class="card">
                  <span>Stock actual</span>
                  <strong>${number(summary.stock_actual)}</strong>
                  <small>Disponible: ${number(summary.stock_disponible)}</small>
                </article>

                <article class="card">
                  <span>Venta neta piezas</span>
                  <strong>${number(summary.piezas_netas_venta_desde_ultima_recepcion)}</strong>
                  <small>Desde ${text(reception.movement_date)}</small>
                </article>
              </div>
            </div>
          </section>

          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Última recepción</p>
                <h2>Origen del cálculo</h2>
              </div>
              <span class="badge neutral">${text(reception.movement_date)}</span>
            </div>

            <dl>
              <div>
                <dt>Recepción</dt>
                <dd>${text(reception.reception_id)}</dd>
              </div>
              <div>
                <dt>Piezas recibidas</dt>
                <dd>${number(reception.quantity)}</dd>
              </div>
              <div>
                <dt>Costo</dt>
                <dd>${money(reception.cost)}</dd>
              </div>
              <div>
                <dt>Stock al recibir</dt>
                <dd>${number(reception.variant_stock)}</dd>
              </div>
              <div class="wide">
                <dt>Nota</dt>
                <dd>${text(reception.note)}</dd>
              </div>
            </dl>
          </section>

          <section class="section-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Movimientos</p>
                <h2>Línea de tiempo desde última recepción</h2>
              </div>
              <span class="badge neutral">${number(movements.length)} movimientos</span>
            </div>

            ${
              movements.length
                ? `<div class="timeline-line">
                    ${movements
                      .map(
                        (item) => `
                          <article class="timeline-item ${movementClass(item.movement_group)}">
                            <div class="timeline-dot"></div>

                            <div class="timeline-date">
                              <strong>${text(item.movement_date)}</strong>
                            </div>

                            <div class="timeline-content">
                              <div class="timeline-top">
                                <div>
                                  <strong>${movementLabel(item)}</strong>
                                  <span>${text(movementReference(item))}</span>
                                </div>
                                <strong class="timeline-qty">${number(item.quantity_signed ?? item.quantity)}</strong>
                              </div>

                              <p>${text(item.note)}</p>
                            </div>
                          </article>
                        `
                      )
                      .join('')}
                  </div>`
                : '<p class="muted">Sin movimientos encontrados.</p>'
            }
          </section>

          <section class="section-card muted-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Cobertura revisada</p>
                <h2>Qué se revisó en Bsale</h2>
              </div>
              <span class="badge neutral">Diagnóstico</span>
            </div>

            <div class="coverage-grid">
              <article class="coverage-item">
                <span>Rango consultado</span>
                <strong>${text(data.start_date)} a ${text(data.end_date)}</strong>
                <p>Periodo usado para encontrar la última recepción y las ventas posteriores.</p>
              </article>

              <article class="coverage-item">
                <span>Recepciones revisadas</span>
                <strong>${number(scanStats.receptions?.receptions_seen)}</strong>
                <p>Recepciones de Bsale leídas para buscar la última entrada de este SKU.</p>
              </article>

              <article class="coverage-item">
                <span>Recepciones con este SKU</span>
                <strong>${number(scanStats.receptions?.matches)}</strong>
                <p>Coincidencias encontradas del SKU dentro de las recepciones revisadas.</p>
              </article>

              <article class="coverage-item">
                <span>Documentos de venta revisados</span>
                <strong>${number(scanStats.documents?.documents_seen)}</strong>
                <p>Documentos revisados desde la fecha de la última recepción hasta hoy.</p>
              </article>

              <article class="coverage-item">
                <span>Líneas de documento revisadas</span>
                <strong>${number(scanStats.documents?.details_seen)}</strong>
                <p>Renglones de productos revisados dentro de esos documentos.</p>
              </article>

              <article class="coverage-item">
                <span>Ventas/devoluciones del SKU</span>
                <strong>${number(scanStats.documents?.matches)}</strong>
                <p>Movimientos de venta o devolución encontrados para este SKU.</p>
              </article>
            </div>
          </section>
        `;
      };

      const renderError = (error) => {
        setPdfAvailable(false);

        result.innerHTML = `
          <section class="section-card error-card">
            <div class="section-header">
              <div>
                <p class="section-kicker">Error</p>
                <h2>No se pudo calcular</h2>
              </div>
              <span class="badge danger">Error</span>
            </div>

            <p class="muted">${text(error?.message || error)}</p>
          </section>
        `;
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const searchValue = input.value.trim();
        const officeId = Number(officeSelect.value);
        const lookbackDays = Number(lookbackSelect.value);

        if (!searchValue) {
          setStatus('Escribe un SKU o código de barras.');
          result.innerHTML = '';
          return;
        }

        button.disabled = true;
        lastCalculation = null;
        setPdfAvailable(false);
        result.innerHTML = '';
        setStatus('Calculando sell-through live desde Bsale...');

        const { data, error } = await supabase.functions.invoke('calculate-sell-through-live', {
          body: {
            query: searchValue,
            office_ids: [officeId],
            lookback_days: lookbackDays,
            max_reception_pages_per_office: 0,
            max_document_pages_per_day_type: 0,
            max_reception_details: 1000,
          },
        });

        button.disabled = false;
        setStatus('');

        if (error) {
          renderError(error);
          return;
        }

        if (data?.error) {
          renderError(data.error);
          return;
        }

        renderData(data);
      });
    </script>
  </body>
</html>

